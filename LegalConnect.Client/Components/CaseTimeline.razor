@using LegalConnect.Client.Models.Cases
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JSRuntime
@inject ToastService Toast

<div class="card shadow-sm">
    <div class="card-header bg-light d-flex align-items-center">
        <h6 class="mb-0"><i class="bi bi-clock-history me-2"></i>Activity Timeline</h6>
        @if (!IsLoading)
        {
            <span class="badge bg-secondary ms-2">@Activities.Count</span>
        }
    </div>
    <div class="card-body p-3">
        @if (IsLoading)
        {
            <div class="d-flex align-items-center text-muted gap-2 py-2">
                <span class="spinner-border spinner-border-sm"></span>
                <span>Loading timeline...</span>
            </div>
        }
        else if (!Activities.Any())
        {
            <div class="text-center py-4 text-muted">
                <i class="bi bi-clock display-4"></i>
                <p class="mt-2 mb-0">No activity recorded yet</p>
            </div>
        }
        else
        {
            <div class="timeline">
                @foreach (var activity in Activities.OrderByDescending(a => a.ActivityDate))
                {
                    <div class="timeline-item">
                        <div class="timeline-icon">
                            <i class="@activity.ActivityIcon"></i>
                        </div>
                        <div class="timeline-content">
                            <div class="d-flex justify-content-between align-items-start flex-wrap gap-1 mb-1">
                                <div>
                                    @if (!string.IsNullOrWhiteSpace(activity.Title))
                                    {
                                        <div class="fw-semibold">@activity.Title</div>
                                    }
                                    <div class="d-flex align-items-center gap-1 flex-wrap">
                                        <span class="small text-muted">@activity.ActivityTypeName</span>
                                        @if (!string.IsNullOrWhiteSpace(activity.Category) && activity.Category != "Other")
                                        {
                                            <span class="@CategoryBadgeClass(activity.Category)" style="font-size:.65rem">@activity.Category</span>
                                        }
                                    </div>
                                </div>
                                <span class="text-muted" style="font-size:.75rem">
                                    @activity.ActivityDate.ToString("d MMM yyyy, HH:mm")
                                </span>
                            </div>
                            @if (activity.EventDate.HasValue)
                            {
                                <div class="text-info small mb-1">
                                    <i class="bi bi-calendar-event me-1"></i>Event: @activity.EventDate.Value.ToString("d MMM yyyy")
                                </div>
                            }
                            <p class="mb-1 small" style="white-space: pre-wrap;">@activity.Description</p>
                            @if (activity.LinkedDocuments.Any())
                            {
                                <div class="mt-1 pt-1 border-top">
                                    <div class="text-muted mb-1" style="font-size:.7rem">
                                        <i class="bi bi-paperclip me-1"></i>Linked Documents
                                    </div>
                                    @foreach (var doc in activity.LinkedDocuments)
                                    {
                                        <button class="btn btn-link p-0 d-inline-flex align-items-center gap-1 me-2 text-decoration-none small border-0 bg-transparent"
                                                @onclick="() => DownloadDocAsync(doc.DocumentId, doc.FileName)">
                                            <i class="bi bi-file-earmark text-secondary"></i>
                                            <span class="text-truncate" style="max-width:140px">@doc.FileName</span>
                                        </button>
                                    }
                                </div>
                            }
                            <div class="text-muted mt-1" style="font-size:.75rem">
                                <i class="bi bi-person me-1"></i>@activity.CreatedByName
                                <span class="badge bg-light text-secondary border ms-1" style="font-size:.65rem">
                                    @activity.CreatedByRole
                                </span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<style>
    .timeline {
        position: relative;
        padding-left: 2rem;
    }
    .timeline::before {
        content: '';
        position: absolute;
        left: .75rem;
        top: 0;
        bottom: 0;
        width: 2px;
        background: #dee2e6;
    }
    .timeline-item {
        position: relative;
        margin-bottom: 1.25rem;
    }
    .timeline-item:last-child {
        margin-bottom: 0;
    }
    .timeline-icon {
        position: absolute;
        left: -2rem;
        top: .125rem;
        width: 1.5rem;
        height: 1.5rem;
        background: white;
        border: 2px solid #dee2e6;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .75rem;
    }
    .timeline-content {
        background: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: .375rem;
        padding: .6rem .85rem;
    }
</style>

@code {
    [Parameter] public List<CaseActivityDto> Activities { get; set; } = [];
    [Parameter] public bool IsLoading { get; set; }

    private async Task DownloadDocAsync(int docId, string fileName)
    {
        try
        {
            var http = HttpClientFactory.CreateClient("secured");
            var response = await http.GetAsync($"case-documents/{docId}/download");
            if (!response.IsSuccessStatusCode) { Toast.ShowError("Download failed or access denied."); return; }

            var bytes = await response.Content.ReadAsByteArrayAsync();
            var contentType = response.Content.Headers.ContentType?.MediaType ?? "application/octet-stream";
            await JSRuntime.InvokeVoidAsync("downloadFileFromBytes", fileName, contentType, Convert.ToBase64String(bytes));
        }
        catch { Toast.ShowError("Download failed."); }
    }

    private string CategoryBadgeClass(string category) => category switch
    {
        "Court Hearing"    => "badge bg-danger",
        "Judgement Day"    => "badge bg-dark",
        "FIR"              => "badge bg-warning text-dark",
        "Police Inquiry"   => "badge bg-warning text-dark",
        "Case Submission"  => "badge bg-info text-dark",
        "Payment"          => "badge bg-success",
        "Summons Attended" => "badge bg-secondary",
        "Main Event"       => "badge bg-primary",
        _                  => "badge bg-light text-dark border"
    };
}
