@using LegalConnect.Client.Models.Cases
@using Microsoft.AspNetCore.Components.Forms
@inject IHttpClientFactory HttpClientFactory
@inject ICaseService CaseService
@inject ToastService Toast

<!-- Modal overlay -->
<div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5)">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-upload me-2"></i>Upload Document</h5>
                <button type="button" class="btn-close" @onclick="OnClose" disabled="@_uploading"></button>
            </div>
            <div class="modal-body">
                <!-- File picker -->
                <div class="mb-3">
                    <label class="form-label">File <span class="text-danger">*</span></label>
                    <InputFile class="form-control" OnChange="OnFileSelected" accept=".pdf,.docx,.jpg,.jpeg,.png" />
                    <div class="form-text text-muted">
                        Allowed: PDF, DOCX, JPG, PNG — Max 10 MB
                    </div>
                    @if (_selectedFile != null)
                    {
                        <div class="mt-2 d-flex align-items-center gap-2 text-success small">
                            <i class="bi bi-file-earmark-check"></i>
                            @_selectedFile.Name (@FormatBytes(_selectedFile.Size))
                        </div>
                    }
                    @if (_fileError != null)
                    {
                        <div class="text-danger small mt-1">@_fileError</div>
                    }
                </div>

                <!-- Document type -->
                <div class="mb-3">
                    <label class="form-label">Document Type <span class="text-danger">*</span></label>
                    <select class="form-select" @bind="_documentType">
                        <option value="">— Select type —</option>
                        <option>Petition</option>
                        <option>Affidavit</option>
                        <option>Evidence</option>
                        <option>Judgment</option>
                        <option>Correspondence</option>
                        <option>Contract</option>
                        <option>Other</option>
                    </select>
                </div>

                <!-- Private / Public visibility toggle -->
                <div class="form-check mt-2">
                    <input class="form-check-input" type="checkbox" id="isPrivate" @bind="_isPrivate"
                           @bind:after="OnPrivateChanged" />
                    <label class="form-check-label" for="isPrivate">
                        @if (IsLawyer)
                        {
                            <span>Mark as Private <span class="text-muted small">(only you can see — hidden from client)</span></span>
                        }
                        else
                        {
                            <span>Mark as Private <span class="text-muted small">(only you can see — hidden from lawyers)</span></span>
                        }
                    </label>
                </div>
                <div class="text-muted small mt-1 mb-3">
                    @if (!_isPrivate)
                    {
                        @if (IsLawyer)
                        {
                            <span><i class="bi bi-eye me-1 text-success"></i>Public — your client can view this document</span>
                        }
                        else
                        {
                            <span><i class="bi bi-eye me-1 text-success"></i>Public — your lawyers can view this document</span>
                        }
                    }
                    else
                    {
                        <span><i class="bi bi-eye-slash me-1 text-warning"></i>Private — only you can see this document</span>
                    }
                </div>

                <!-- Available for Hire Request (client only, not private) -->
                @if (!IsLawyer && !_isPrivate)
                {
                    <div class="form-check mt-2 mb-1">
                        <input class="form-check-input" type="checkbox" id="availableForDeal"
                               @bind="_isAvailableForDeal" />
                        <label class="form-check-label" for="availableForDeal">
                            <span>
                                Share with lawyers evaluating this case
                                <span class="text-muted small">(visible on Hire Requests before hiring)</span>
                            </span>
                        </label>
                    </div>
                    @if (_isAvailableForDeal)
                    {
                        <div class="text-primary small mb-3">
                            <i class="bi bi-briefcase me-1"></i>This document will be shared with lawyers you send hire requests to.
                        </div>
                    }
                    else
                    {
                        <div class="text-muted small mb-3">
                            <i class="bi bi-briefcase me-1"></i>Not shared for hire request evaluation.
                        </div>
                    }
                }
                else if (!IsLawyer && _isPrivate)
                {
                    <div class="mb-3"></div>
                }

                <!-- Lawyer-wise sharing (client only, not private, multiple lawyers) -->
                @if (!IsLawyer && !_isPrivate && AssignedLawyers.Count > 1)
                {
                    <div class="border rounded p-3 bg-light mb-3">
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" id="shareAll"
                                   checked="@_shareWithAll"
                                   @onchange="e => { _shareWithAll = (bool)(e.Value ?? true); if (_shareWithAll) _selectedLawyerIds.Clear(); }" />
                            <label class="form-check-label fw-semibold" for="shareAll">
                                Share with all lawyers
                                <span class="text-muted fw-normal small">(all @AssignedLawyers.Count lawyers)</span>
                            </label>
                        </div>
                        @if (!_shareWithAll)
                        {
                            <div class="ms-3">
                                <div class="text-muted small mb-2">Select which lawyers can see this document:</div>
                                @foreach (var lawyer in AssignedLawyers)
                                {
                                    var lawyerId = lawyer.LawyerProfileId;
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox"
                                               id="lawyer_@lawyerId"
                                               checked="@_selectedLawyerIds.Contains(lawyerId)"
                                               @onchange="e => ToggleLawyerShare(lawyerId, (bool)(e.Value ?? false))" />
                                        <label class="form-check-label small" for="lawyer_@lawyerId">
                                            @lawyer.LawyerFullName
                                            @if (!string.IsNullOrEmpty(lawyer.CategoryName))
                                            {
                                                <span class="text-muted"> — @lawyer.CategoryName</span>
                                            }
                                        </label>
                                    </div>
                                }
                                @if (_selectedLawyerIds.Count == 0)
                                {
                                    <div class="text-warning small mt-1">
                                        <i class="bi bi-exclamation-triangle me-1"></i>No lawyers selected — document won't be visible to any lawyer.
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }

                <!-- Link to Activity Timeline (lawyer only, optional) -->
                @if (IsLawyer && Activities.Any())
                {
                    <div class="mb-3">
                        <label class="form-label form-label-sm">
                            <i class="bi bi-clock-history me-1"></i>Link to Activity Timeline
                            <span class="text-muted fw-normal">(optional)</span>
                        </label>
                        <select class="form-select form-select-sm" @bind="_selectedActivityId">
                            <option value="">— None —</option>
                            @foreach (var act in Activities.OrderByDescending(a => a.ActivityDate))
                            {
                                <option value="@act.Id">
                                    @act.ActivityDate.ToString("d MMM yyyy") —
                                    @(string.IsNullOrWhiteSpace(act.Title) ? act.ActivityTypeName : act.Title)
                                    @if (!string.IsNullOrWhiteSpace(act.Category) && act.Category != "Other")
                                    {
                                        <text> (@act.Category)</text>
                                    }
                                </option>
                            }
                        </select>
                    </div>
                }

                @if (_uploading)
                {
                    <div class="mt-3">
                        <div class="progress" style="height:6px">
                            <div class="progress-bar progress-bar-striped progress-bar-animated w-100"></div>
                        </div>
                        <div class="text-center text-muted small mt-1">Uploading...</div>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="OnClose" disabled="@_uploading">Cancel</button>
                <button class="btn btn-primary" @onclick="UploadAsync"
                        disabled="@(_selectedFile == null || string.IsNullOrEmpty(_documentType) || _uploading)">
                    @if (_uploading)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    Upload
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public int CaseId { get; set; }
    [Parameter] public bool IsLawyer { get; set; } = true;
    [Parameter] public List<CaseLawyerDto> AssignedLawyers { get; set; } = [];
    [Parameter] public List<CaseActivityDto> Activities { get; set; } = [];
    [Parameter] public EventCallback OnUploadSuccess { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private IBrowserFile? _selectedFile;
    private string _documentType = "";
    private bool _isPrivate;
    private bool _isAvailableForDeal;
    private bool _shareWithAll = true;
    private readonly HashSet<int> _selectedLawyerIds = [];
    private string _selectedActivityId = "";
    private bool _uploading;
    private string? _fileError;

    private const long MaxFileSizeBytes = 10 * 1024 * 1024; // 10 MB

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        _fileError = null;
        var file = e.File;

        if (file.Size > MaxFileSizeBytes)
        {
            _fileError = $"File is too large ({FormatBytes(file.Size)}). Maximum allowed size is 10 MB.";
            _selectedFile = null;
            return;
        }

        var allowed = new[] { ".pdf", ".docx", ".jpg", ".jpeg", ".png" };
        var ext = Path.GetExtension(file.Name).ToLowerInvariant();
        if (!allowed.Contains(ext))
        {
            _fileError = $"File type '{ext}' is not allowed.";
            _selectedFile = null;
            return;
        }

        _selectedFile = file;
    }

    private void OnPrivateChanged()
    {
        if (_isPrivate)
        {
            _shareWithAll = true;
            _selectedLawyerIds.Clear();
            _isAvailableForDeal = false;
        }
    }

    private void ToggleLawyerShare(int lawyerProfileId, bool isChecked)
    {
        if (isChecked) _selectedLawyerIds.Add(lawyerProfileId);
        else _selectedLawyerIds.Remove(lawyerProfileId);
    }

    private async Task UploadAsync()
    {
        if (_selectedFile == null || string.IsNullOrEmpty(_documentType)) return;

        _uploading = true;
        _fileError = null;

        try
        {
            using var content = new MultipartFormDataContent();

            var stream = _selectedFile.OpenReadStream(MaxFileSizeBytes);
            var fileContent = new StreamContent(stream);
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(
                _selectedFile.ContentType ?? "application/octet-stream");
            content.Add(fileContent, "file", _selectedFile.Name);
            content.Add(new StringContent(_documentType), "DocumentType");
            content.Add(new StringContent(_isPrivate.ToString().ToLower()), "IsPrivate");
            content.Add(new StringContent(_isAvailableForDeal.ToString().ToLower()), "IsAvailableForDeal");

            // Lawyer-wise sharing: send selected IDs if not sharing with all
            if (!IsLawyer && !_isPrivate && AssignedLawyers.Count > 1 && !_shareWithAll)
            {
                foreach (var id in _selectedLawyerIds)
                    content.Add(new StringContent(id.ToString()), "SharedWithLawyerIds");
            }

            var http = HttpClientFactory.CreateClient("secured");
            var response = await http.PostAsync($"cases/{CaseId}/documents", content);
            var result = await response.Content.ReadFromJsonAsync<ApiResponse<CaseDocumentDto>>();

            if (result?.Success == true)
            {
                // Link to activity if one was selected
                if (!string.IsNullOrEmpty(_selectedActivityId)
                    && int.TryParse(_selectedActivityId, out var actId)
                    && result.Data?.Id > 0)
                {
                    var linkResp = await CaseService.LinkDocumentToActivityAsync(CaseId, actId, result.Data.Id);
                    if (linkResp?.Success == true)
                        Toast.ShowSuccess("Document uploaded and linked to activity.");
                    else
                        Toast.ShowSuccess("Document uploaded. (Activity link failed — try linking manually.)");
                }
                else
                {
                    Toast.ShowSuccess("Document uploaded successfully.");
                }
                await OnUploadSuccess.InvokeAsync();
            }
            else
            {
                _fileError = result?.Message ?? "Upload failed. Please try again.";
            }
        }
        catch (Exception ex)
        {
            _fileError = $"Upload error: {ex.Message}";
        }
        finally
        {
            _uploading = false;
        }
    }

    private static string FormatBytes(long bytes) => bytes < 1024 * 1024
        ? $"{bytes / 1024.0:F1} KB"
        : $"{bytes / (1024.0 * 1024):F1} MB";
}
