@inject IDealService DealService
@inject ToastService Toast

<div class="card shadow-sm">
    <div class="card-header bg-white d-flex align-items-center justify-content-between">
        <h6 class="mb-0"><i class="bi bi-chat-dots me-2"></i>Conversation</h6>
        @if (_messages.Count > 0)
        {
            <span class="badge bg-secondary">@_messages.Count messages</span>
        }
    </div>
    <div class="card-body p-0">
        <!-- Messages area -->
        <div style="height:350px;overflow-y:auto;padding:1rem;" id="chat-messages-@HireRequestId">
            @if (_loadingMessages)
            {
                <div class="text-center py-3"><span class="spinner-border spinner-border-sm text-primary"></span></div>
            }
            else if (_messages.Count == 0)
            {
                <div class="text-center py-4 text-muted">
                    <i class="bi bi-chat-left-text display-6"></i>
                    <p class="mt-2 mb-0">No messages yet. Start the conversation!</p>
                </div>
            }
            else
            {
                @foreach (var msg in _messages)
                {
                    var isMe = msg.SenderUserId == CurrentUserId;
                    <div class="d-flex mb-3 @(isMe ? "justify-content-end" : "justify-content-start")">
                        @if (!isMe)
                        {
                            <img src="@(msg.SenderPicture ?? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(msg.SenderName)}&size=32&background=6c757d&color=fff")"
                                 class="rounded-circle me-2 flex-shrink-0"
                                 style="width:32px;height:32px;object-fit:cover;" />
                        }
                        <div style="max-width:75%;">
                            <div class="p-2 rounded-3 @(isMe ? "bg-primary text-white" : "bg-light text-dark")" style="word-break:break-word;">
                                @msg.Content
                            </div>
                            <div class="@(isMe ? "text-end" : "")" style="font-size:.7rem;color:#999;margin-top:2px;">
                                @msg.SenderName &middot; @msg.SentAt.ToString("MMM d, h:mm tt")
                            </div>
                        </div>
                        @if (isMe)
                        {
                            <img src="@(msg.SenderPicture ?? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(msg.SenderName)}&size=32&background=1a56db&color=fff")"
                                 class="rounded-circle ms-2 flex-shrink-0"
                                 style="width:32px;height:32px;object-fit:cover;" />
                        }
                    </div>
                }
            }
        </div>

        <!-- Input area -->
        @if (!Disabled)
        {
            <div class="border-top p-3">
                <div class="input-group">
                    <input type="text" class="form-control" placeholder="Type a message..."
                           @bind="_newMessage" @bind:event="oninput"
                           @onkeydown="HandleKeyDown"
                           disabled="@_sending" />
                    <button class="btn btn-primary" @onclick="SendAsync" disabled="@(_sending || string.IsNullOrWhiteSpace(_newMessage))">
                        @if (_sending)
                        {
                            <span class="spinner-border spinner-border-sm"></span>
                        }
                        else
                        {
                            <i class="bi bi-send-fill"></i>
                        }
                    </button>
                </div>
            </div>
        }
        else
        {
            <div class="border-top p-3 text-center text-muted small">
                <i class="bi bi-lock me-1"></i>Conversation is closed.
            </div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public int HireRequestId { get; set; }
    [Parameter, EditorRequired] public int CurrentUserId { get; set; }
    [Parameter] public bool Disabled { get; set; }

    private List<HireRequestMessageDto> _messages = [];
    private bool _loadingMessages = true;
    private string _newMessage = string.Empty;
    private bool _sending;

    protected override async Task OnParametersSetAsync()
    {
        await LoadMessagesAsync();
    }

    private async Task LoadMessagesAsync()
    {
        _loadingMessages = true;
        StateHasChanged();
        var resp = await DealService.GetMessagesAsync(HireRequestId);
        _messages = resp?.Data ?? [];
        _loadingMessages = false;

        // Mark as read
        if (_messages.Any(m => !m.IsRead && m.SenderUserId != CurrentUserId))
        {
            await DealService.MarkMessagesReadAsync(HireRequestId);
        }
    }

    private async Task SendAsync()
    {
        if (string.IsNullOrWhiteSpace(_newMessage)) return;
        _sending = true;
        var resp = await DealService.SendMessageAsync(HireRequestId, new SendMessageDto { Content = _newMessage.Trim() });
        if (resp?.Success == true && resp.Data != null)
        {
            _messages.Add(resp.Data);
            _newMessage = string.Empty;
        }
        else
        {
            Toast.ShowError(resp?.Message ?? "Failed to send message.");
        }
        _sending = false;
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendAsync();
        }
    }
}
