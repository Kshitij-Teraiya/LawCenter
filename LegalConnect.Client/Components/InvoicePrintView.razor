@using LegalConnect.Client.Models.Deals
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<!-- Full-screen modal overlay -->
<div class="invoice-overlay" @onclick="HandleOverlayClick">
    <div class="invoice-modal" @onclick:stopPropagation="true">

        <!-- Toolbar (hidden on print) -->
        <div class="invoice-toolbar d-print-none">
            <span class="fw-semibold small">Invoice — @Invoice.InvoiceNumber</span>
            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-primary" @onclick="PrintAsync">
                    <i class="bi bi-printer me-1"></i>Print / Download PDF
                </button>
                <button class="btn btn-sm btn-outline-secondary" @onclick="OnClose">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        </div>

        <!-- ── Printable Invoice Body ── -->
        <div class="invoice-print-body" id="invoice-print-area">

            <!-- Header: Logo + Firm Details + Invoice Info -->
            <div class="inv-header">
                <div class="inv-firm">
                    @if (!string.IsNullOrEmpty(Invoice.LawyerFirmLogoPath))
                    {
                        <img src="@Invoice.LawyerFirmLogoPath" alt="Firm Logo" class="inv-logo" />
                    }
                    <div class="inv-firm-name">@(Invoice.LawyerFirmName ?? Invoice.LawyerFullName ?? "Law Firm")</div>
                    @if (!string.IsNullOrEmpty(Invoice.LawyerAddress))
                    {
                        <div class="inv-firm-address">@Invoice.LawyerAddress</div>
                    }
                    @if (!string.IsNullOrEmpty(Invoice.LawyerPhone) || !string.IsNullOrEmpty(Invoice.LawyerEmail))
                    {
                        <div class="inv-firm-contact">
                            @if (!string.IsNullOrEmpty(Invoice.LawyerPhone)) { <span><i class="bi bi-telephone"></i> @Invoice.LawyerPhone</span> }
                            @if (!string.IsNullOrEmpty(Invoice.LawyerEmail)) { <span class="ms-2"><i class="bi bi-envelope"></i> @Invoice.LawyerEmail</span> }
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Invoice.LawyerGSTNumber))
                    {
                        <div class="inv-gst">GST No: <strong>@Invoice.LawyerGSTNumber</strong></div>
                    }
                </div>
                <div class="inv-meta">
                    <div class="inv-title">INVOICE</div>
                    <table class="inv-meta-table">
                        <tr><td>Invoice No</td><td><strong>@Invoice.InvoiceNumber</strong></td></tr>
                        <tr><td>Date</td><td>@Invoice.CreatedAt.ToString("d MMM yyyy")</td></tr>
                        @if (Invoice.DueDate.HasValue)
                        {
                            <tr><td>Due Date</td><td>@Invoice.DueDate.Value.ToString("d MMM yyyy")</td></tr>
                        }
                        <tr><td>Status</td><td><span class="inv-status-badge @GetStatusClass(Invoice.Status)">@Invoice.Status</span></td></tr>
                    </table>
                </div>
            </div>

            <hr class="inv-divider" />

            <!-- Bill To -->
            <div class="inv-bill-section">
                <div class="inv-bill-to">
                    <div class="inv-section-label">BILL TO</div>
                    <div class="inv-client-name">@(Invoice.ClientFullName ?? "Client")</div>
                </div>
                <div class="inv-bill-from">
                    <div class="inv-section-label">FROM</div>
                    <div class="inv-lawyer-name">@Invoice.LawyerFullName</div>
                    @if (!string.IsNullOrEmpty(Invoice.LawyerFirmName) && Invoice.LawyerFirmName != Invoice.LawyerFullName)
                    {
                        <div class="text-muted small">@Invoice.LawyerFirmName</div>
                    }
                </div>
            </div>

            <!-- Invoice Line Items -->
            <table class="inv-table">
                <thead>
                    <tr>
                        <th style="width:50%">Description</th>
                        <th>Type</th>
                        <th class="text-end">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>@(string.IsNullOrEmpty(Invoice.Description) ? (Invoice.ChargeType ?? "Legal Services") : Invoice.Description)</td>
                        <td>@(Invoice.ChargeType ?? "—")</td>
                        <td class="text-end">&#8377;@Invoice.Amount.ToString("N2")</td>
                    </tr>
                </tbody>
            </table>

            <!-- Summary -->
            <div class="inv-summary">
                <table class="inv-summary-table">
                    <tr>
                        <td>Subtotal</td>
                        <td class="text-end">&#8377;@Invoice.Amount.ToString("N2")</td>
                    </tr>
                    @if (Invoice.GstRate > 0)
                    {
                        <tr>
                            <td>GST (@Invoice.GstRate%)</td>
                            <td class="text-end">&#8377;@Invoice.GstAmount.ToString("N2")</td>
                        </tr>
                    }
                    <tr class="inv-total-row">
                        <td><strong>Total</strong></td>
                        <td class="text-end"><strong>&#8377;@Invoice.TotalAmount.ToString("N2")</strong></td>
                    </tr>
                </table>
            </div>

            <!-- Bank Details -->
            @if (!string.IsNullOrEmpty(Invoice.LawyerBankDetails))
            {
                <div class="inv-bank mt-4">
                    <div class="inv-section-label">BANK DETAILS</div>
                    <div class="inv-bank-text" style="white-space:pre-wrap">@Invoice.LawyerBankDetails</div>
                </div>
            }

            <!-- Signature -->
            <div class="inv-footer mt-4">
                <div class="inv-sign">
                    @if (!string.IsNullOrEmpty(Invoice.LawyerAuthorizedSignImagePath))
                    {
                        <img src="@Invoice.LawyerAuthorizedSignImagePath" alt="Signature" class="inv-sign-img" />
                    }
                    <div class="inv-sign-line"></div>
                    <div class="small text-muted">Authorized Signatory</div>
                    <div class="small">@Invoice.LawyerFullName</div>
                </div>
            </div>

            <!-- Notes & Terms -->
            @if (!string.IsNullOrEmpty(Invoice.LawyerNotesForInvoice))
            {
                <div class="inv-notes mt-3">
                    <div class="inv-section-label">NOTES</div>
                    <div style="white-space:pre-wrap; font-size:.82rem">@Invoice.LawyerNotesForInvoice</div>
                </div>
            }
            @if (!string.IsNullOrEmpty(Invoice.LawyerTermsAndConditions))
            {
                <div class="inv-terms mt-2">
                    <div class="inv-section-label">TERMS &amp; CONDITIONS</div>
                    <div style="white-space:pre-wrap; font-size:.78rem; color:#666">@Invoice.LawyerTermsAndConditions</div>
                </div>
            }
        </div><!-- /invoice-print-body -->
    </div><!-- /invoice-modal -->
</div><!-- /invoice-overlay -->

<style>
    /* Overlay */
    .invoice-overlay {
        position: fixed; inset: 0; background: rgba(0,0,0,.55);
        z-index: 2000; display: flex; align-items: flex-start; justify-content: center;
        overflow-y: auto; padding: 2rem 1rem;
    }
    .invoice-modal {
        background: white; border-radius: .5rem; width: 100%; max-width: 780px;
        box-shadow: 0 8px 32px rgba(0,0,0,.25);
    }
    .invoice-toolbar {
        padding: .75rem 1.25rem; border-bottom: 1px solid #dee2e6;
        display: flex; justify-content: space-between; align-items: center;
    }
    .invoice-print-body { padding: 2rem 2.5rem; }

    /* Header */
    .inv-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 2rem; }
    .inv-logo { max-height: 60px; max-width: 160px; object-fit: contain; margin-bottom: .5rem; display: block; }
    .inv-firm-name { font-size: 1.1rem; font-weight: 700; color: #1a1a2e; }
    .inv-firm-address { font-size: .82rem; color: #555; margin-top: .2rem; }
    .inv-firm-contact { font-size: .78rem; color: #666; margin-top: .2rem; }
    .inv-gst { font-size: .78rem; color: #666; margin-top: .2rem; }
    .inv-meta { text-align: right; flex-shrink: 0; }
    .inv-title { font-size: 2rem; font-weight: 800; letter-spacing: 4px; color: #1a1a2e; }
    .inv-meta-table { font-size: .82rem; margin-top: .5rem; border-collapse: collapse; margin-left: auto; }
    .inv-meta-table td { padding: .1rem .4rem; }
    .inv-meta-table td:first-child { color: #888; }
    .inv-status-badge { padding: .15rem .5rem; border-radius: .25rem; font-size: .72rem; font-weight: 600; }
    .inv-status-paid { background: #d1fae5; color: #065f46; }
    .inv-status-accepted { background: #dbeafe; color: #1d4ed8; }
    .inv-status-pending { background: #fef9c3; color: #854d0e; }
    .inv-status-rejected { background: #fee2e2; color: #991b1b; }

    /* Divider */
    .inv-divider { border-color: #1a1a2e; margin: 1.25rem 0; }

    /* Bill section */
    .inv-bill-section { display: flex; gap: 3rem; margin-bottom: 1.5rem; }
    .inv-section-label { font-size: .68rem; font-weight: 700; letter-spacing: 2px; color: #888; text-transform: uppercase; margin-bottom: .25rem; }
    .inv-client-name, .inv-lawyer-name { font-weight: 600; font-size: 1rem; }

    /* Table */
    .inv-table { width: 100%; border-collapse: collapse; font-size: .88rem; }
    .inv-table th { background: #1a1a2e; color: white; padding: .5rem .75rem; font-weight: 600; font-size: .8rem; letter-spacing: .5px; }
    .inv-table td { padding: .6rem .75rem; border-bottom: 1px solid #f0f0f0; }
    .inv-table tr:last-child td { border-bottom: none; }

    /* Summary */
    .inv-summary { display: flex; justify-content: flex-end; margin-top: 1rem; }
    .inv-summary-table { min-width: 240px; border-collapse: collapse; font-size: .88rem; }
    .inv-summary-table td { padding: .3rem .5rem; }
    .inv-summary-table td:last-child { text-align: right; }
    .inv-total-row td { border-top: 2px solid #1a1a2e; padding-top: .5rem; font-size: 1rem; }

    /* Footer / Signature */
    .inv-footer { display: flex; justify-content: flex-end; }
    .inv-sign { text-align: center; min-width: 180px; }
    .inv-sign-img { max-height: 60px; max-width: 160px; object-fit: contain; margin-bottom: .3rem; }
    .inv-sign-line { border-top: 1px solid #333; margin-bottom: .3rem; }

    /* Bank / Notes / Terms */
    .inv-bank, .inv-notes, .inv-terms { font-size: .82rem; }
    .inv-bank-text { margin-top: .25rem; }

    /* Print is handled via window.printInvoice() popup — no page-level print CSS needed. */
</style>

@code {
    [Parameter, EditorRequired] public InvoiceDto Invoice { get; set; } = new();
    [Parameter] public EventCallback OnClose { get; set; }

    private IJSObjectReference? _jsModule;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // JS Isolation: load the colocated .razor.js module.
            // The module is guaranteed to be available before PrintAsync can be called
            // (the Print button is only visible after this render completes).
            _jsModule = await JSRuntime.InvokeAsync<IJSObjectReference>(
                "import", "./Components/InvoicePrintView.razor.js");
        }
    }

    private void HandleOverlayClick() => OnClose.InvokeAsync();

    private async Task PrintAsync()
    {
        if (_jsModule is not null)
            await _jsModule.InvokeVoidAsync("printInvoice", "invoice-print-area");
    }

    public async ValueTask DisposeAsync()
    {
        if (_jsModule is not null)
        {
            try { await _jsModule.DisposeAsync(); }
            catch (JSDisconnectedException) { /* component torn down during navigation */ }
        }
    }

    private static string GetStatusClass(string status) => status switch
    {
        "Paid"     => "inv-status-paid",
        "Accepted" => "inv-status-accepted",
        "Pending"  => "inv-status-pending",
        "Rejected" => "inv-status-rejected",
        _          => "inv-status-pending"
    };
}
