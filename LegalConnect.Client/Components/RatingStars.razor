<span class="stars" title="@Rating.ToString("F1") out of 5">
    @for (int i = 1; i <= 5; i++)
    {
        int index = i;
        if (Rating >= index)
        {
            <i class="bi bi-star-fill"></i>
        }
        else if (Rating >= index - 0.5m)
        {
            <i class="bi bi-star-half"></i>
        }
        else
        {
            <i class="bi bi-star empty"></i>
        }
    }
    @if (ShowValue)
    {
        <span class="ms-1 text-muted small fw-normal">@Rating.ToString("F1")</span>
    }
</span>

@code {
    [Parameter] public decimal Rating    { get; set; }
    [Parameter] public bool   ShowValue  { get; set; } = true;
}
