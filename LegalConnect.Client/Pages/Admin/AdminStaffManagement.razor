@page "/admin/admin-staff"
@attribute [Authorize(Roles = "Admin")]
@inject IAdminStaffService StaffService
@inject ToastService Toast

<PageTitle>Admin Staff &mdash; LawCity</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h4 class="fw-bold mb-0">
            <i class="bi bi-person-gear me-2 text-primary"></i>Admin Staff Management
        </h4>
        <button class="btn btn-primary" @onclick="OpenCreateModal">
            <i class="bi bi-plus-lg me-1"></i>Create Staff Account
        </button>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5"><span class="spinner-border text-primary"></span></div>
    }
    else if (_staffList.Count == 0)
    {
        <div class="text-center py-5">
            <i class="bi bi-person-x display-1 text-muted"></i>
            <h5 class="mt-3 text-muted">No admin staff accounts yet</h5>
            <p class="text-muted">Create your first admin staff member to delegate platform operations.</p>
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Department</th>
                            <th>Roles</th>
                            <th>Status</th>
                            <th>Created</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in _staffList)
                        {
                            <tr class="@(!s.IsActive ? "table-secondary" : "")">
                                <td class="fw-medium">@s.FullName</td>
                                <td class="text-muted">@s.Email</td>
                                <td>@(s.Department ?? "&mdash;")</td>
                                <td>
                                    <div class="d-flex flex-wrap gap-1">
                                        @foreach (var r in s.Roles)
                                        {
                                            <span class="badge bg-info-subtle text-info border" style="font-size:.72rem;">@FormatRoleName(r)</span>
                                        }
                                    </div>
                                </td>
                                <td>
                                    @if (s.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactive</span>
                                    }
                                </td>
                                <td class="text-muted small">@s.CreatedAt.ToString("d MMM yyyy")</td>
                                <td class="text-end">
                                    <div class="btn-group btn-group-sm">
                                        <button class="btn btn-outline-primary" title="Edit Roles" @onclick="() => OpenEditRolesModal(s)">
                                            <i class="bi bi-shield-check"></i>
                                        </button>
                                        <button class="btn @(s.IsActive ? "btn-outline-warning" : "btn-outline-success")" title="@(s.IsActive ? "Deactivate" : "Activate")" @onclick="() => ToggleActiveAsync(s)">
                                            <i class="bi @(s.IsActive ? "bi-pause-circle" : "bi-play-circle")"></i>
                                        </button>
                                        <button class="btn btn-outline-secondary" title="Reset Password" @onclick="() => OpenResetPasswordModal(s)">
                                            <i class="bi bi-key"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@* ──── Create Staff Modal ──── *@
@if (_showCreateModal)
{
    <div class="modal d-block" tabindex="-1" style="background-color:rgba(0,0,0,.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-person-plus me-2"></i>Create Admin Staff</h5>
                    <button type="button" class="btn-close" @onclick="CloseModals"></button>
                </div>
                <EditForm Model="_createModel" OnValidSubmit="CreateStaffAsync">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">First Name <span class="text-danger">*</span></label>
                                <InputText class="form-control" @bind-Value="_createModel.FirstName" />
                                <ValidationMessage For="() => _createModel.FirstName" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Last Name <span class="text-danger">*</span></label>
                                <InputText class="form-control" @bind-Value="_createModel.LastName" />
                                <ValidationMessage For="() => _createModel.LastName" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Email <span class="text-danger">*</span></label>
                                <InputText class="form-control" @bind-Value="_createModel.Email" />
                                <ValidationMessage For="() => _createModel.Email" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Phone</label>
                                <InputText class="form-control" @bind-Value="_createModel.PhoneNumber" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Password <span class="text-danger">*</span></label>
                                <InputText type="password" class="form-control" @bind-Value="_createModel.Password" />
                                <ValidationMessage For="() => _createModel.Password" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Department</label>
                                <InputText class="form-control" @bind-Value="_createModel.Department" />
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-medium">Assign Roles <span class="text-danger">*</span></label>
                                <div class="d-flex flex-wrap gap-3">
                                    @foreach (var role in _availableRoles)
                                    {
                                        var isChecked = _createModel.Roles.Contains(role.Name);
                                        <div class="form-check">
                                            <input type="checkbox" class="form-check-input" id="create-@role.Name"
                                                   checked="@isChecked"
                                                   @onchange="(e) => ToggleCreateRole(role.Name, (bool)(e.Value ?? false))" />
                                            <label class="form-check-label" for="create-@role.Name">
                                                <span class="fw-medium">@FormatRoleName(role.Name)</span>
                                                <br /><small class="text-muted">@role.Description</small>
                                            </label>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseModals">Cancel</button>
                        <button type="submit" class="btn btn-primary" disabled="@(_saving || _createModel.Roles.Count == 0)">
                            @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Create Staff Account
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@* ──── Edit Roles Modal ──── *@
@if (_showEditRolesModal && _editTarget != null)
{
    <div class="modal d-block" tabindex="-1" style="background-color:rgba(0,0,0,.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-shield-check me-2"></i>Edit Roles &mdash; @_editTarget.FullName</h5>
                    <button type="button" class="btn-close" @onclick="CloseModals"></button>
                </div>
                <div class="modal-body">
                    <div class="d-flex flex-column gap-3">
                        @foreach (var role in _availableRoles)
                        {
                            var isChecked = _editRolesModel.Roles.Contains(role.Name);
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input" id="edit-@role.Name"
                                       checked="@isChecked"
                                       @onchange="(e) => ToggleEditRole(role.Name, (bool)(e.Value ?? false))" />
                                <label class="form-check-label" for="edit-@role.Name">
                                    <span class="fw-medium">@FormatRoleName(role.Name)</span>
                                    <br /><small class="text-muted">@role.Description</small>
                                </label>
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModals">Cancel</button>
                    <button type="button" class="btn btn-primary" disabled="@(_saving || _editRolesModel.Roles.Count == 0)" @onclick="UpdateRolesAsync">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Save Roles
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* ──── Reset Password Modal ──── *@
@if (_showResetPasswordModal && _resetTarget != null)
{
    <div class="modal d-block" tabindex="-1" style="background-color:rgba(0,0,0,.5);">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-key me-2"></i>Reset Password</h5>
                    <button type="button" class="btn-close" @onclick="CloseModals"></button>
                </div>
                <EditForm Model="_resetPasswordModel" OnValidSubmit="ResetPasswordAsync">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        <p class="text-muted small mb-3">Set a new password for <strong>@_resetTarget.FullName</strong>.</p>
                        <label class="form-label">New Password <span class="text-danger">*</span></label>
                        <InputText type="password" class="form-control" @bind-Value="_resetPasswordModel.NewPassword" />
                        <ValidationMessage For="() => _resetPasswordModel.NewPassword" />
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseModals">Cancel</button>
                        <button type="submit" class="btn btn-warning" disabled="@_saving">
                            @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Reset Password
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private List<AdminStaffDto> _staffList = [];
    private List<AdminStaffRoleInfoDto> _availableRoles = [];
    private bool _loading = true;
    private bool _saving;

    // Create modal
    private bool _showCreateModal;
    private CreateAdminStaffModel _createModel = new();

    // Edit roles modal
    private bool _showEditRolesModal;
    private AdminStaffDto? _editTarget;
    private UpdateAdminStaffRolesModel _editRolesModel = new();

    // Reset password modal
    private bool _showResetPasswordModal;
    private AdminStaffDto? _resetTarget;
    private ResetAdminStaffPasswordModel _resetPasswordModel = new();

    protected override async Task OnInitializedAsync()
    {
        var rolesResp = await StaffService.GetAvailableRolesAsync();
        _availableRoles = rolesResp?.Data ?? [];
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        var resp = await StaffService.GetAllAsync();
        _staffList = resp?.Data ?? [];
        _loading = false;
    }

    // ── Create ────────────────────────────────────────────
    private void OpenCreateModal()
    {
        _createModel = new();
        _showCreateModal = true;
    }

    private void ToggleCreateRole(string roleName, bool isChecked)
    {
        if (isChecked && !_createModel.Roles.Contains(roleName))
            _createModel.Roles.Add(roleName);
        else if (!isChecked)
            _createModel.Roles.Remove(roleName);
    }

    private async Task CreateStaffAsync()
    {
        if (_createModel.Roles.Count == 0)
        {
            Toast.ShowError("Please assign at least one role.");
            return;
        }
        _saving = true;
        var resp = await StaffService.CreateAsync(_createModel);
        if (resp?.Success == true)
        {
            Toast.ShowSuccess("Admin staff account created.");
            CloseModals();
            await LoadAsync();
        }
        else Toast.ShowError(resp?.Message ?? "Failed to create staff account.");
        _saving = false;
    }

    // ── Edit Roles ────────────────────────────────────────
    private void OpenEditRolesModal(AdminStaffDto staff)
    {
        _editTarget = staff;
        _editRolesModel = new UpdateAdminStaffRolesModel { Roles = new List<string>(staff.Roles) };
        _showEditRolesModal = true;
    }

    private void ToggleEditRole(string roleName, bool isChecked)
    {
        if (isChecked && !_editRolesModel.Roles.Contains(roleName))
            _editRolesModel.Roles.Add(roleName);
        else if (!isChecked)
            _editRolesModel.Roles.Remove(roleName);
    }

    private async Task UpdateRolesAsync()
    {
        if (_editTarget == null || _editRolesModel.Roles.Count == 0)
        {
            Toast.ShowError("Please assign at least one role.");
            return;
        }
        _saving = true;
        var (success, error) = await StaffService.UpdateRolesAsync(_editTarget.Id, _editRolesModel);
        if (success)
        {
            Toast.ShowSuccess("Roles updated.");
            CloseModals();
            await LoadAsync();
        }
        else Toast.ShowError(error ?? "Failed to update roles.");
        _saving = false;
    }

    // ── Toggle Active ─────────────────────────────────────
    private async Task ToggleActiveAsync(AdminStaffDto staff)
    {
        var (success, error) = await StaffService.ToggleActiveAsync(staff.Id);
        if (success)
        {
            Toast.ShowSuccess(staff.IsActive ? "Staff deactivated." : "Staff activated.");
            await LoadAsync();
        }
        else Toast.ShowError(error ?? "Failed to toggle status.");
    }

    // ── Reset Password ────────────────────────────────────
    private void OpenResetPasswordModal(AdminStaffDto staff)
    {
        _resetTarget = staff;
        _resetPasswordModel = new();
        _showResetPasswordModal = true;
    }

    private async Task ResetPasswordAsync()
    {
        if (_resetTarget == null) return;
        _saving = true;
        var (success, error) = await StaffService.ResetPasswordAsync(_resetTarget.Id, _resetPasswordModel);
        if (success)
        {
            Toast.ShowSuccess("Password reset successfully.");
            CloseModals();
        }
        else Toast.ShowError(error ?? "Failed to reset password.");
        _saving = false;
    }

    // ── Helpers ───────────────────────────────────────────
    private void CloseModals()
    {
        _showCreateModal = false;
        _showEditRolesModal = false;
        _showResetPasswordModal = false;
        _editTarget = null;
        _resetTarget = null;
    }

    private static string FormatRoleName(string role) => role switch
    {
        "LawyerApprovalManager" => "Lawyer Approval Manager",
        "UserManagementStaff" => "User Management Staff",
        "SupportStaff" => "Support Staff",
        "DisputeRefundManager" => "Dispute & Refund Manager",
        "FinanceStaff" => "Finance Staff",
        _ => role
    };
}
