@page "/admin/approve-lawyers"
@attribute [Authorize(Roles = "Admin")]
@inject IAdminService AdminService
@inject ToastService Toast

<PageTitle>Approve Lawyers – LegalConnect</PageTitle>

<div class="container-fluid">
    <h4 class="fw-bold mb-4">
        <i class="bi bi-person-check me-2 text-primary"></i>Pending Lawyer Approvals
    </h4>

    @if (_loading)
    {
        <LoadingSpinner />
    }
    else if (_lawyers.Count == 0)
    {
        <div class="text-center py-5">
            <i class="bi bi-check-circle-fill text-success" style="font-size:3rem;"></i>
            <h5 class="mt-3">All clear!</h5>
            <p class="text-muted">No pending lawyer applications.</p>
        </div>
    }
    else
    {
        <div class="lc-card">
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>City</th>
                            <th>Specialization</th>
                            <th>Bar No.</th>
                            <th>Registered</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var lawyer in _lawyers)
                        {
                            var l = lawyer;
                            <tr>
                                <td class="fw-semibold">@lawyer.FullName</td>
                                <td class="small text-muted">@lawyer.Email</td>
                                <td>@lawyer.City</td>
                                <td>@lawyer.CategoryName</td>
                                <td><code>@lawyer.BarCouncilNumber</code></td>
                                <td class="small text-muted">@lawyer.RegisteredAt.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <div class="d-flex gap-2">
                                        <button class="btn btn-sm btn-success"
                                                @onclick="() => Approve(l)"
                                                disabled="@_busy">
                                            <i class="bi bi-check-lg me-1"></i>Approve
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger"
                                                @onclick="() => PromptReject(l)"
                                                disabled="@_busy">
                                            <i class="bi bi-x-lg me-1"></i>Reject
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<!-- Reject Reason Modal -->
<ConfirmationModal @ref="_rejectModal"
                   Title="Reject Application"
                   Message="@($"Reject {_toReject?.FullName}? This will notify them by email.")"
                   ConfirmText="Reject"
                   ConfirmButtonClass="btn-danger"
                   OnConfirmed="ConfirmReject" />

@code {
    private List<PendingLawyerDto> _lawyers = [];
    private bool _loading = true;
    private bool _busy;
    private PendingLawyerDto? _toReject;
    private ConfirmationModal? _rejectModal;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        _loading = true;
        _lawyers = await AdminService.GetPendingLawyersAsync();
        _loading = false;
    }

    private async Task Approve(PendingLawyerDto lawyer)
    {
        _busy = true;
        var (ok, err) = await AdminService.ApproveLawyerAsync(lawyer.Id);
        if (ok)
        {
            Toast.ShowSuccess($"{lawyer.FullName} approved!");
            _lawyers.Remove(lawyer);
        }
        else Toast.ShowError(err ?? "Failed.");
        _busy = false;
    }

    private void PromptReject(PendingLawyerDto lawyer)
    {
        _toReject = lawyer;
        _rejectModal?.Show();
    }

    private async Task ConfirmReject()
    {
        if (_toReject is null) return;
        var (ok, err) = await AdminService.RejectLawyerAsync(_toReject.Id, "Application rejected.");
        if (ok) { Toast.ShowInfo($"{_toReject.FullName} rejected."); _lawyers.Remove(_toReject); }
        else     Toast.ShowError(err ?? "Failed.");
        _toReject = null;
    }
}
