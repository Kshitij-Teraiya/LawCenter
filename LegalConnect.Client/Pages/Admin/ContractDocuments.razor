@page "/admin/contracts"
@attribute [Authorize(Roles = "Admin")]
@inject IContractService ContractService
@inject ToastService Toast
@inject IJSRuntime JS

<PageTitle>Contract Documents – Admin</PageTitle>

<div class="container-fluid py-4">
    <h4 class="fw-bold mb-4"><i class="bi bi-file-earmark-text me-2"></i>Contract Documents</h4>

    @* Filters *@
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small">Type</label>
                    <select class="form-select form-select-sm" @bind="_filter.ContractType">
                        <option value="">All Types</option>
                        <option value="RegistrationTnC">Registration T&amp;C</option>
                        <option value="ProposalDraft">Proposal Draft</option>
                        <option value="ProposalFinal">Proposal Contract</option>
                        <option value="RefundInvoice">Refund Invoice</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Lawyer Name</label>
                    <input class="form-control form-control-sm" @bind="_filter.LawyerName" placeholder="Search..." />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">From</label>
                    <input type="date" class="form-control form-control-sm" @bind="_filter.DateFrom" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small">To</label>
                    <input type="date" class="form-control form-control-sm" @bind="_filter.DateTo" />
                </div>
                <div class="col-md-2">
                    <button class="btn btn-primary btn-sm w-100" @onclick="LoadAsync">
                        <i class="bi bi-search me-1"></i>Search
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    }
    else if (_contracts?.Items.Count == 0)
    {
        <div class="text-center text-muted py-5"><i class="bi bi-inbox fs-1 d-block mb-2"></i>No contracts found.</div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Title</th>
                            <th>Type</th>
                            <th>Lawyer</th>
                            <th>Generated</th>
                            <th>Size</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in _contracts!.Items)
                        {
                            <tr>
                                <td class="small">@c.Title</td>
                                <td><span class="badge bg-secondary-subtle text-secondary">@ContractTypeNames.Display(c.ContractType)</span></td>
                                <td class="small">@(c.LawyerName ?? "—")</td>
                                <td class="small">@c.GeneratedAt.ToString("dd MMM yyyy")</td>
                                <td class="small">@c.FileSizeFormatted</td>
                                <td>
                                    @if (c.IsAccepted)
                                    {
                                        <span class="badge bg-success-subtle text-success">Accepted</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning-subtle text-warning">Draft</span>
                                    }
                                </td>
                                <td>
                                    <button class="btn btn-outline-primary btn-sm"
                                            @onclick="() => DownloadAsync(c.Id, c.FileName)"
                                            title="Download">
                                        <i class="bi bi-download"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @* Pagination *@
        @if (_contracts!.TotalPages > 1)
        {
            <div class="d-flex justify-content-center mt-3 gap-2">
                <button class="btn btn-outline-secondary btn-sm" disabled="@(!_contracts.HasPrevious)"
                        @onclick='() => ChangePage(_filter.Page - 1)'>
                    &laquo;
                </button>
                <span class="btn btn-light btn-sm disabled">@_filter.Page / @_contracts.TotalPages</span>
                <button class="btn btn-outline-secondary btn-sm" disabled="@(!_contracts.HasNext)"
                        @onclick='() => ChangePage(_filter.Page + 1)'>
                    &raquo;
                </button>
            </div>
        }
    }
</div>

@code {
    private ContractFilterModel _filter = new();
    private PagedResult<LegalContractModel>? _contracts;
    private bool _loading;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            var resp = await ContractService.GetContractsAsync(_filter);
            _contracts = resp?.Data ?? new PagedResult<LegalContractModel>();
        }
        catch { Toast.ShowError("Failed to load contracts."); }
        finally { _loading = false; }
    }

    private async Task ChangePage(int p) { _filter.Page = p; await LoadAsync(); }

    private async Task DownloadAsync(int id, string fileName)
    {
        try
        {
            var bytes = await ContractService.DownloadContractAsync(id);
            if (bytes == null || bytes.Length == 0)
            {
                Toast.ShowError("Failed to download contract.");
                return;
            }
            await JS.InvokeVoidAsync("downloadFileFromBytes", fileName, "application/pdf", Convert.ToBase64String(bytes));
        }
        catch
        {
            Toast.ShowError("Failed to download contract.");
        }
    }
}
