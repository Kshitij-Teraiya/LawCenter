@page "/admin/revenue"
@attribute [Authorize(Roles = "Admin")]
@inject IAdminService AdminService

<PageTitle>Revenue Stats – LegalConnect</PageTitle>

<div class="container-fluid">
    <h4 class="fw-bold mb-4">
        <i class="bi bi-graph-up me-2 text-primary"></i>Revenue Statistics
    </h4>

    @if (_loading) { <LoadingSpinner /> }
    else if (_stats is not null)
    {
        <!-- Top KPI Cards -->
        <div class="row g-3 mb-5">
            <div class="col-6 col-md-3">
                <div class="stat-card">
                    <div class="stat-icon bg-success bg-opacity-10 text-success">
                        <i class="bi bi-cash-stack"></i>
                    </div>
                    <div>
                        <div class="stat-value">৳@_stats.TotalRevenue.ToString("N0")</div>
                        <div class="stat-label">Total Revenue</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card">
                    <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                        <i class="bi bi-calendar-month"></i>
                    </div>
                    <div>
                        <div class="stat-value">৳@_stats.MonthlyRevenue.ToString("N0")</div>
                        <div class="stat-label">This Month</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card">
                    <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                        <i class="bi bi-percent"></i>
                    </div>
                    <div>
                        <div class="stat-value">৳@_stats.PlatformCommission.ToString("N0")</div>
                        <div class="stat-label">Platform Earned</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card">
                    <div class="stat-icon bg-info bg-opacity-10 text-info">
                        <i class="bi bi-calendar-check"></i>
                    </div>
                    <div>
                        <div class="stat-value">@_stats.TotalAppointments.ToString("N0")</div>
                        <div class="stat-label">Total Appointments</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Monthly Breakdown Table -->
        <div class="lc-card">
            <h6 class="fw-bold mb-3">Month-by-Month Breakdown</h6>
            <div class="table-responsive">
                <table class="table table-hover align-middle small">
                    <thead class="table-light">
                        <tr>
                            <th>Month</th>
                            <th>Appointments</th>
                            <th>Gross Revenue</th>
                            <th>Platform Commission</th>
                            <th>% of Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in _stats.MonthlyBreakdown)
                        {
                            var pct = _stats.TotalRevenue > 0
                                ? (m.Revenue / _stats.TotalRevenue * 100m)
                                : 0;
                            <tr>
                                <td>@m.Month</td>
                                <td>@m.AppointmentCount</td>
                                <td>৳@m.Revenue.ToString("N2")</td>
                                <td class="text-success fw-semibold">
                                    ৳@(m.Revenue * 0.05m).ToString("N2")
                                </td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="flex-grow-1" style="height:6px;background:#e5e7eb;border-radius:3px;">
                                            <div style="height:100%;border-radius:3px;background:var(--lc-primary);width:@pct.ToString("F1")%"></div>
                                        </div>
                                        <span class="text-muted small">@pct.ToString("F1")%</span>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private RevenueStatsDto? _stats;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _stats   = await AdminService.GetRevenueStatsAsync();
        _loading = false;
    }
}
