@page "/admin/support"
@attribute [Authorize(Roles = "Admin,AdminStaff")]
@inject ISupportService SupportService
@inject ToastService Toast
@inject NavigationManager Nav

<PageTitle>Support Tickets &mdash; LawCity Admin</PageTitle>

<div class="container-fluid py-4">
    <h3 class="mb-4"><i class="bi bi-life-preserver me-2"></i>All Support Tickets</h3>

    <!-- Summary Badges -->
    <div class="d-flex gap-3 flex-wrap mb-4">
        <div class="badge bg-primary fs-6 py-2 px-3">
            <i class="bi bi-envelope-open me-1"></i>Open: @_tickets.Count(t => t.Status == "Open")
        </div>
        <div class="badge bg-warning text-dark fs-6 py-2 px-3">
            <i class="bi bi-hourglass-split me-1"></i>In Progress: @_tickets.Count(t => t.Status == "InProgress")
        </div>
        <div class="badge bg-success fs-6 py-2 px-3">
            <i class="bi bi-check-circle me-1"></i>Resolved: @_tickets.Count(t => t.Status == "Resolved")
        </div>
        <div class="badge bg-secondary fs-6 py-2 px-3">
            <i class="bi bi-archive me-1"></i>Closed: @_tickets.Count(t => t.Status == "Closed")
        </div>
    </div>

    <!-- Filters -->
    <div class="card shadow-sm mb-4">
        <div class="card-body py-2">
            <div class="row g-2 align-items-end">
                <div class="col-auto">
                    <label class="form-label small mb-1">Status</label>
                    <select class="form-select form-select-sm" style="width:150px" @bind="_filterStatus" @bind:after="LoadAsync">
                        <option value="">All Statuses</option>
                        @foreach (var s in TicketStatuses.All)
                        {
                            <option value="@s">@(s == "InProgress" ? "In Progress" : s)</option>
                        }
                    </select>
                </div>
                <div class="col-auto">
                    <label class="form-label small mb-1">Category</label>
                    <select class="form-select form-select-sm" style="width:150px" @bind="_filterCategory" @bind:after="LoadAsync">
                        <option value="">All Categories</option>
                        @foreach (var c in TicketCategories.All)
                        {
                            <option value="@c">@c</option>
                        }
                    </select>
                </div>
                <div class="col-auto">
                    <button class="btn btn-sm btn-outline-secondary" @onclick="ClearFilters">
                        <i class="bi bi-x-lg me-1"></i>Clear
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5"><span class="spinner-border text-primary"></span></div>
    }
    else if (FilteredTickets.Count == 0)
    {
        <div class="text-center py-5">
            <i class="bi bi-inbox display-1 text-muted"></i>
            <h5 class="mt-3 text-muted">No tickets found</h5>
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Subject</th>
                            <th>Submitted By</th>
                            <th>Category</th>
                            <th>Priority</th>
                            <th>Status</th>
                            <th>Updated</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in FilteredTickets)
                        {
                            <tr>
                                <td>
                                    <div class="fw-medium">@t.Subject</div>
                                    <div class="text-muted small">@t.MessageCount message(s)</div>
                                </td>
                                <td>
                                    <div>@t.UserFullName</div>
                                    <span class="badge @(t.UserRole == "Lawyer" ? "bg-info-subtle text-info" : "bg-success-subtle text-success")" style="font-size:.7rem">@t.UserRole</span>
                                </td>
                                <td><span class="badge bg-light text-dark border">@t.Category</span></td>
                                <td><span class="@PriorityBadge(t.Priority)">@t.Priority</span></td>
                                <td><span class="@StatusBadge(t.Status)">@FormatStatus(t.Status)</span></td>
                                <td class="text-muted small">@t.UpdatedAt.ToString("d MMM yyyy")</td>
                                <td>
                                    <a href="/admin/support/@t.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private List<SupportTicketDto> _tickets = [];
    private bool _loading = true;
    private string _filterStatus = string.Empty;
    private string _filterCategory = string.Empty;
    private string _search = string.Empty;

    private List<SupportTicketDto> FilteredTickets => _tickets
        .Where(t => string.IsNullOrEmpty(_search) ||
                     t.Subject.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                     t.UserFullName.Contains(_search, StringComparison.OrdinalIgnoreCase))
        .ToList();

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        var resp = await SupportService.GetAllTicketsAsync(
            string.IsNullOrEmpty(_filterStatus) ? null : _filterStatus,
            string.IsNullOrEmpty(_filterCategory) ? null : _filterCategory);
        _tickets = resp?.Data ?? [];
        _loading = false;
    }

    private async Task ClearFilters()
    {
        _filterStatus = string.Empty;
        _filterCategory = string.Empty;
        _search = string.Empty;
        await LoadAsync();
    }

    private static string PriorityBadge(string p) => p switch
    {
        "Low" => "badge bg-secondary",
        "Medium" => "badge bg-info",
        "High" => "badge bg-warning text-dark",
        "Urgent" => "badge bg-danger",
        _ => "badge bg-secondary"
    };

    private static string StatusBadge(string s) => s switch
    {
        "Open" => "badge bg-primary",
        "InProgress" => "badge bg-warning text-dark",
        "Resolved" => "badge bg-success",
        "Closed" => "badge bg-secondary",
        _ => "badge bg-secondary"
    };

    private static string FormatStatus(string s) => s switch
    {
        "InProgress" => "In Progress",
        _ => s
    };
}
