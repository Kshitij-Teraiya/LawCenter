@page "/book/{LawyerId:int}"
@attribute [Authorize(Roles = "Client")]
@inject ILawyerService LawyerService
@inject IAppointmentService AppointmentService
@inject NavigationManager Navigation
@inject ToastService Toast

<PageTitle>Book Appointment – LegalConnect</PageTitle>

<div class="container py-4" style="max-width:720px;">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/lawyers">Lawyers</a></li>
            <li class="breadcrumb-item">
                <a href="/lawyers/@LawyerId">@(_lawyer?.FullName ?? "Profile")</a>
            </li>
            <li class="breadcrumb-item active">Book Appointment</li>
        </ol>
    </nav>

    @if (_loadingLawyer)
    {
        <LoadingSpinner />
    }
    else if (_lawyer is null)
    {
        <div class="alert alert-danger">Lawyer not found.</div>
    }
    else if (_confirmed)
    {
        <!-- Success State -->
        <div class="lc-card text-center py-5">
            <i class="bi bi-check-circle-fill text-success" style="font-size:3.5rem;"></i>
            <h4 class="mt-3 fw-bold">Appointment Confirmed!</h4>
            <p class="text-muted">
                Your appointment with <strong>@_lawyer.FullName</strong> has been booked.
                You'll receive a confirmation shortly.
            </p>
            <div class="d-flex justify-content-center gap-3 mt-4">
                <a href="/client/appointments" class="btn btn-primary">
                    View My Appointments
                </a>
                <a href="/lawyers" class="btn btn-outline-secondary">
                    Browse More Lawyers
                </a>
            </div>
        </div>
    }
    else
    {
        <!-- Lawyer Summary -->
        <div class="lc-card mb-4 d-flex align-items-center gap-3">
            <img src="@(_lawyer.ProfilePictureUrl ?? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(_lawyer.FullName)}&background=1a56db&color=fff&size=64")"
                 class="rounded-circle" style="width:64px;height:64px;object-fit:cover;" alt="" />
            <div>
                <h6 class="fw-bold mb-0">@_lawyer.FullName</h6>
                <p class="text-muted small mb-0">@_lawyer.Category?.Name · @_lawyer.City</p>
                <RatingStars Rating="@_lawyer.AverageRating" ShowValue="true" />
            </div>
            <div class="ms-auto text-end">
                <div class="text-muted small">Fee</div>
                <div class="fw-bold text-primary fs-5">৳@_lawyer.ConsultationFee.ToString("N0")</div>
            </div>
        </div>

        <!-- Booking Form -->
        <div class="lc-card">
            <h5 class="fw-bold mb-4">Select Date &amp; Time</h5>

            <EditForm Model="@_model" OnValidSubmit="HandleBook">
                <DataAnnotationsValidator />

                @if (!string.IsNullOrWhiteSpace(_error))
                {
                    <div class="alert alert-danger py-2">@_error</div>
                }

                <!-- Date Picker -->
                <div class="mb-4">
                    <label class="form-label fw-medium">Appointment Date</label>
                    <input type="date"
                           class="form-control"
                           @bind="_model.AppointmentDate"
                           @bind:after="LoadSlots"
                           min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")"
                           max="@DateTime.Today.AddDays(60).ToString("yyyy-MM-dd")" />
                    <ValidationMessage For="@(() => _model.AppointmentDate)" class="text-danger small" />
                </div>

                <!-- Time Slots -->
                <div class="mb-4">
                    <label class="form-label fw-medium">Available Time Slots</label>
                    @if (_loadingSlots)
                    {
                        <div class="text-muted small"><span class="spinner-border spinner-border-sm me-2"></span>Loading slots…</div>
                    }
                    else if (_slots.Count == 0)
                    {
                        <div class="alert alert-warning py-2 small">
                            No slots available for this date. Please choose another date.
                        </div>
                    }
                    else
                    {
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var slot in _slots)
                            {
                                var s = slot;
                                bool selected = _model.StartTime == s.StartTime;
                                <button type="button"
                                        class="btn btn-sm @(selected ? "btn-primary" : "btn-outline-secondary") @(!s.IsAvailable ? "disabled" : "")"
                                        @onclick="() => _model.StartTime = s.StartTime"
                                        disabled="@(!s.IsAvailable)">
                                    @s.DisplayTime
                                </button>
                            }
                        </div>
                        <ValidationMessage For="@(() => _model.StartTime)" class="text-danger small" />
                    }
                </div>

                <!-- Notes -->
                <div class="mb-4">
                    <label class="form-label fw-medium">Notes (optional)</label>
                    <InputTextArea @bind-Value="_model.Notes" class="form-control"
                                   rows="3" placeholder="Describe your case briefly…"
                                   maxlength="500" />
                </div>

                <!-- Fee Summary -->
                <div class="bg-light rounded-3 p-3 mb-4">
                    <div class="d-flex justify-content-between small mb-1">
                        <span>Consultation Fee</span>
                        <span>৳@_lawyer.ConsultationFee.ToString("N2")</span>
                    </div>
                    <div class="d-flex justify-content-between small mb-1 text-muted">
                        <span>Platform Fee (5%)</span>
                        <span>৳@(_lawyer.ConsultationFee * 0.05m).ToString("N2")</span>
                    </div>
                    <hr class="my-2" />
                    <div class="d-flex justify-content-between fw-bold">
                        <span>Total</span>
                        <span class="text-primary">৳@((_lawyer.ConsultationFee * 1.05m).ToString("N2"))</span>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2" disabled="@_booking">
                    @if (_booking)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    <i class="bi bi-calendar-check me-2"></i>Confirm Booking
                </button>
            </EditForm>
        </div>
    }
</div>

@code {
    [Parameter] public int LawyerId { get; set; }

    private LawyerDto? _lawyer;
    private readonly BookAppointmentDto _model = new();
    private List<TimeSlotDto> _slots = [];
    private bool _loadingLawyer = true;
    private bool _loadingSlots;
    private bool _booking;
    private bool _confirmed;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        _model.LawyerId = LawyerId;
        _model.AppointmentDate = DateTime.Today.AddDays(1);
        _lawyer = await LawyerService.GetLawyerByIdAsync(LawyerId);
        _loadingLawyer = false;
        await LoadSlots();
    }

    private async Task LoadSlots()
    {
        _loadingSlots = true;
        _slots = await AppointmentService.GetAvailableSlotsAsync(LawyerId, _model.AppointmentDate);
        _loadingSlots = false;
    }

    private async Task HandleBook()
    {
        _booking = true; _error = null;
        var (success, error, appt) = await AppointmentService.BookAppointmentAsync(_model);

        if (success)
        {
            _confirmed = true;
            Toast.ShowSuccess("Appointment booked successfully!");
        }
        else
        {
            _error = error;
        }

        _booking = false;
    }
}
