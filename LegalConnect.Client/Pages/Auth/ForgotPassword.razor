@page "/forgot-password"
@layout MinimalLayout
@inject IAuthService AuthService

<PageTitle>Forgot Password – LegalConnect</PageTitle>

<div class="min-vh-100 d-flex align-items-center justify-content-center bg-light py-5">
    <div class="card shadow-sm border-0" style="width:100%;max-width:420px;">
        <div class="card-body p-4 p-md-5">

            <div class="text-center mb-4">
                <a href="/" class="lc-brand justify-content-center">
                    <img src="image/logo.jpeg" alt="LegalConnect" class="lc-brand-logo-lg" />
                </a>
            </div>

            @if (_emailSent)
            {
                <div class="text-center">
                    <i class="bi bi-envelope-check-fill text-primary" style="font-size:3rem;"></i>
                    <h5 class="mt-3">Check your email</h5>
                    <p class="text-muted">
                        We've sent password reset instructions to
                        <strong>@_model.Email</strong>.
                    </p>
                    <a href="/login" class="btn btn-outline-primary mt-2">Back to Login</a>
                </div>
            }
            else
            {
                <h5 class="fw-semibold mb-1">Reset your password</h5>
                <p class="text-muted small mb-4">
                    Enter your email and we'll send you a reset link.
                </p>

                <EditForm Model="@_model" OnValidSubmit="HandleSubmit">
                    <DataAnnotationsValidator />

                    @if (!string.IsNullOrWhiteSpace(_error))
                    {
                        <div class="alert alert-danger py-2">@_error</div>
                    }

                    <div class="mb-3">
                        <label class="form-label fw-medium">Email address</label>
                        <InputText @bind-Value="_model.Email" class="form-control"
                                   placeholder="you@example.com" autocomplete="email" />
                        <ValidationMessage For="@(() => _model.Email)" class="text-danger small" />
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2" disabled="@_loading">
                        @if (_loading)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Send Reset Link
                    </button>
                </EditForm>

                <p class="text-center mt-3 mb-0">
                    <a href="/login"><i class="bi bi-arrow-left me-1"></i>Back to login</a>
                </p>
            }
        </div>
    </div>
</div>

@code {
    private readonly ForgotPasswordDto _model = new();
    private bool _loading;
    private bool _emailSent;
    private string? _error;

    private async Task HandleSubmit()
    {
        _loading = true; _error = null;
        var (success, error) = await AuthService.ForgotPasswordAsync(_model);
        _loading = false;

        if (success) _emailSent = true;
        else _error = error;
    }
}
