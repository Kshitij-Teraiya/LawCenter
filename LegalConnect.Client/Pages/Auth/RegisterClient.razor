@page "/register-client"
@layout MinimalLayout
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ToastService Toast
@inject IJSRuntime JS
@inject IConfiguration Config

<PageTitle>Register as Client &mdash; LegalConnect</PageTitle>

<div class="min-vh-100 d-flex align-items-center justify-content-center bg-light py-5">
    <div class="card shadow-sm border-0" style="width:100%;max-width:500px;">
        <div class="card-body p-4 p-md-5">

            <div class="text-center mb-4">
                <a href="/" class="lc-brand justify-content-center">
                    <img src="image/logo.jpeg" alt="LegalConnect" class="lc-brand-logo-lg" />
                </a>
                <p class="text-muted mt-2 mb-0">Create your client account</p>
            </div>

            <!-- Google Sign-Up -->
            @if (_googleLoading)
            {
                <div class="text-center py-2">
                    <span class="spinner-border spinner-border-sm text-primary me-2"></span>
                    <span class="text-muted small">Creating account with Google...</span>
                </div>
            }

            <div id="google-signup-btn" class="d-flex justify-content-center"></div>

            <div class="d-flex align-items-center my-3">
                <hr class="flex-grow-1" />
                <span class="px-3 text-muted small">or register with email</span>
                <hr class="flex-grow-1" />
            </div>

            <EditForm Model="@_model" OnValidSubmit="HandleRegister">
                <DataAnnotationsValidator />

                @if (!string.IsNullOrWhiteSpace(_error))
                {
                    <div class="alert alert-danger py-2">
                        <i class="bi bi-exclamation-circle me-2"></i>@_error
                    </div>
                }

                <div class="row g-3">
                    <div class="col-6">
                        <label class="form-label fw-medium">First Name</label>
                        <InputText @bind-Value="_model.FirstName" class="form-control" placeholder="John" />
                        <ValidationMessage For="@(() => _model.FirstName)" class="text-danger small" />
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-medium">Last Name</label>
                        <InputText @bind-Value="_model.LastName" class="form-control" placeholder="Doe" />
                        <ValidationMessage For="@(() => _model.LastName)" class="text-danger small" />
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-medium">Email</label>
                        <InputText @bind-Value="_model.Email" class="form-control"
                                   placeholder="you@example.com" autocomplete="email" />
                        <ValidationMessage For="@(() => _model.Email)" class="text-danger small" />
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-medium">Phone Number</label>
                        <InputText @bind-Value="_model.PhoneNumber" class="form-control"
                                   placeholder="+880 1XXX-XXXXXX" />
                        <ValidationMessage For="@(() => _model.PhoneNumber)" class="text-danger small" />
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-medium">City</label>
                        <InputText @bind-Value="_model.City" class="form-control" placeholder="Dhaka" />
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-medium">Password</label>
                        <InputText @bind-Value="_model.Password" type="password"
                                   class="form-control" placeholder="Min. 8 characters"
                                   autocomplete="new-password" />
                        <ValidationMessage For="@(() => _model.Password)" class="text-danger small" />
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-medium">Confirm Password</label>
                        <InputText @bind-Value="_model.ConfirmPassword" type="password"
                                   class="form-control" placeholder="Repeat password"
                                   autocomplete="new-password" />
                        <ValidationMessage For="@(() => _model.ConfirmPassword)" class="text-danger small" />
                    </div>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2 mt-4" disabled="@_loading">
                    @if (_loading)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    Create Account
                </button>
            </EditForm>

            <p class="text-center mt-3 mb-0">
                Already have an account? <a href="/login">Sign in</a>
            </p>
            <p class="text-center mb-0 small text-muted">
                Are you a lawyer? <a href="/register-lawyer">Register as Lawyer</a>
            </p>
        </div>
    </div>
</div>

@code {
    private readonly RegisterClientDto _model = new();
    private bool _loading;
    private bool _googleLoading;
    private string? _error;
    private DotNetObjectReference<RegisterClient>? _dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            var clientId = Config["Google:ClientId"] ?? "";
            await JS.InvokeVoidAsync("googleAuth.initialize", clientId, _dotNetRef, "google-signup-btn");
        }
    }

    [JSInvokable]
    public async Task OnGoogleSignIn(string credential)
    {
        _googleLoading = true;
        _error = null;
        StateHasChanged();

        var (success, error) = await AuthService.GoogleLoginAsync(credential);

        if (success)
        {
            Toast.ShowSuccess("Account created! Welcome to LegalConnect.");
            Navigation.NavigateTo("/client/dashboard");
        }
        else
        {
            _error = error;
        }

        _googleLoading = false;
        StateHasChanged();
    }

    private async Task HandleRegister()
    {
        _loading = true; _error = null;
        var (success, error) = await AuthService.RegisterClientAsync(_model);

        if (success)
        {
            Toast.ShowSuccess("Account created! Welcome to LegalConnect.");
            Navigation.NavigateTo("/client/dashboard");
        }
        else
        {
            _error = error;
        }

        _loading = false;
    }

    public void Dispose()
    {
        _dotNetRef?.Dispose();
    }
}
