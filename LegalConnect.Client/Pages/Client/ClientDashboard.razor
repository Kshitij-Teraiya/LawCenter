@page "/client/dashboard"
@attribute [Authorize(Roles = "Client")]
@inject IAppointmentService AppointmentService
@inject IAuthService AuthService

<PageTitle>Client Dashboard – LegalConnect</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-0">Welcome back, @_name 👋</h4>
            <p class="text-muted mb-0 small">Here's a summary of your activity</p>
        </div>
        <a href="/lawyers" class="btn btn-primary">
            <i class="bi bi-search me-2"></i>Find a Lawyer
        </a>
    </div>

    <!-- Stats Row -->
    <div class="row g-3 mb-4">
        @foreach (var (icon, label, value, color) in _stats)
        {
            <div class="col-6 col-md-3">
                <div class="stat-card">
                    <div class="stat-icon @color">
                        <i class="@icon"></i>
                    </div>
                    <div>
                        <div class="stat-value">@value</div>
                        <div class="stat-label">@label</div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Recent Appointments -->
    <div class="lc-card">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h6 class="fw-bold mb-0">Recent Appointments</h6>
            <a href="/client/appointments" class="small">View all</a>
        </div>

        @if (_loading)
        {
            <LoadingSpinner Size="1.5" Message="" />
        }
        else if (_appointments.Count == 0)
        {
            <div class="text-center py-4">
                <i class="bi bi-calendar-x text-muted" style="font-size:2.5rem;"></i>
                <p class="text-muted mt-2 mb-3">No appointments yet.</p>
                <a href="/lawyers" class="btn btn-outline-primary btn-sm">
                    Book Your First Appointment
                </a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle small">
                    <thead class="table-light">
                        <tr>
                            <th>Lawyer</th>
                            <th>Date &amp; Time</th>
                            <th>Fee</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var appt in _appointments)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <img src="@(appt.LawyerProfilePicture ?? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(appt.LawyerName)}&size=32&background=1a56db&color=fff")"
                                             class="rounded-circle" style="width:32px;height:32px;object-fit:cover;" alt="" />
                                        @appt.LawyerName
                                    </div>
                                </td>
                                <td>@appt.AppointmentDate.ToString("MMM dd, yyyy")<br />
                                    <span class="text-muted">@DateTime.Today.Add(appt.StartTime).ToString("hh:mm tt")</span>
                                </td>
                                <td>৳@appt.TotalAmount.ToString("N0")</td>
                                <td>
                                    <span class="badge @GetStatusBadge(appt.Status)">
                                        @appt.Status
                                    </span>
                                </td>
                                <td>
                                    <a href="/lawyers/@appt.LawyerId" class="btn btn-sm btn-outline-primary">
                                        View
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private string _name = "";
    private bool _loading = true;
    private List<AppointmentDto> _appointments = [];

    private (string icon, string label, string value, string color)[] _stats =
        Array.Empty<(string, string, string, string)>();

    protected override async Task OnInitializedAsync()
    {
        _name = await AuthService.GetCurrentUserNameAsync() ?? "Client";
        var result = await AppointmentService.GetMyAppointmentsAsync(1, 5);
        _appointments = result?.Items ?? [];

        var total     = result?.TotalCount ?? 0;
        var upcoming  = _appointments.Count(a => a.Status == AppointmentStatus.Confirmed);
        var completed = _appointments.Count(a => a.Status == AppointmentStatus.Completed);
        var spent     = _appointments.Where(a => a.Status == AppointmentStatus.Completed)
                                     .Sum(a => a.TotalAmount);

        _stats = [
            ("bi bi-calendar-check", "Total Bookings", total.ToString(), "bg-primary bg-opacity-10 text-primary"),
            ("bi bi-calendar-event", "Upcoming",       upcoming.ToString(), "bg-success bg-opacity-10 text-success"),
            ("bi bi-check-circle",  "Completed",       completed.ToString(), "bg-info bg-opacity-10 text-info"),
            ("bi bi-cash-stack",    "Total Spent",     $"৳{spent:N0}", "bg-warning bg-opacity-10 text-warning"),
        ];

        _loading = false;
    }

    private static string GetStatusBadge(AppointmentStatus s) => s switch
    {
        AppointmentStatus.Confirmed  => "bg-success",
        AppointmentStatus.Pending    => "bg-warning text-dark",
        AppointmentStatus.Cancelled  => "bg-danger",
        AppointmentStatus.Completed  => "bg-secondary",
        _                            => "bg-light text-dark"
    };
}
