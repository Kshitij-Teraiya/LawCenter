@page "/client/documents"
@using LegalConnect.Client.Models.Cases
@using LegalConnect.Client.Services
@using LegalConnect.Client.Components
@attribute [Authorize(Roles = "Client")]
@inject ICaseService CaseService
@inject ToastService Toast
@inject NavigationManager Nav
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JSRuntime

<PageTitle>My Documents &mdash; LawCity</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0"><i class="bi bi-folder2 text-primary me-2"></i>My Documents</h2>
            <p class="text-muted mb-0">All documents across your cases</p>
        </div>
    </div>

    <!-- Filters -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Filter by Case</label>
                    <select class="form-select" @bind="_selectedCaseId" @bind:after="LoadDocumentsAsync">
                        <option value="0">— All Cases —</option>
                        @foreach (var c in _cases)
                        {
                            <option value="@c.Id">@c.CaseTitle</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Document Type</label>
                    <select class="form-select" @bind="_docType" @bind:after="LoadDocumentsAsync">
                        <option value="">All Types</option>
                        <option>Petition</option>
                        <option>Affidavit</option>
                        <option>Evidence</option>
                        <option>Judgment</option>
                        <option>Correspondence</option>
                        <option>Contract</option>
                        <option>Other</option>
                    </select>
                </div>
                @if (_selectedCaseId > 0)
                {
                    <div class="col-md-2">
                        <button class="btn btn-outline-primary" @onclick="() => _showUploadModal = true">
                            <i class="bi bi-upload me-1"></i>Upload
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>

    @if (_loadingDocs)
    {
        <LoadingSpinner Message="Loading documents..." />
    }
    else if (_documents.Count == 0)
    {
        <div class="text-center py-5">
            <i class="bi bi-file-earmark-x display-1 text-muted"></i>
            <h4 class="mt-3 text-muted">
                @(_selectedCaseId == 0 ? "Select a case to view documents" : "No documents found")
            </h4>
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Document</th>
                            <th>Case</th>
                            <th>Type</th>
                            <th>Uploaded By</th>
                            <th>Date</th>
                            <th>Size</th>
                            <th>Visibility</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var doc in _documents)
                        {
                            var d = doc;
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <i class="@doc.FileIcon fs-5"></i>
                                        <span class="fw-medium">@doc.FileName</span>
                                        @if (doc.IsPrivate)
                                        {
                                            <span class="badge bg-warning text-dark">Private</span>
                                        }
                                        @if (doc.IsAvailableForDeal && !doc.IsPrivate)
                                        {
                                            <span class="badge bg-info text-dark">Hire Request</span>
                                        }
                                    </div>
                                </td>
                                <td>
                                    <a href="/client/cases/@doc.CaseId" class="text-decoration-none">
                                        Case #@doc.CaseId
                                    </a>
                                </td>
                                <td><span class="badge bg-light text-dark">@doc.DocumentType</span></td>
                                <td>
                                    <span class="@(doc.UploadedByRole == "Client" ? "text-primary" : "text-muted") small">
                                        @doc.UploadedByName
                                        @if (doc.UploadedByRole == "Client")
                                        {
                                            <span class="text-muted">(you)</span>
                                        }
                                    </span>
                                </td>
                                <td class="small text-muted">@doc.UploadedDate.ToString("d MMM yyyy")</td>
                                <td class="small">@doc.FileSizeDisplay</td>
                                <td>
                                    @if (doc.UploadedByRole == "Client")
                                    {
                                        <button class="btn btn-sm @(doc.IsPrivate ? "btn-warning" : "btn-outline-secondary")"
                                                title="@(doc.IsPrivate ? "Make Public" : "Make Private")"
                                                disabled="@(_togglingPrivateId == doc.Id)"
                                                @onclick="() => TogglePrivateAsync(d)">
                                            @if (_togglingPrivateId == doc.Id)
                                            {
                                                <span class="spinner-border spinner-border-sm"></span>
                                            }
                                            else if (doc.IsPrivate)
                                            {
                                                <span><i class="bi bi-lock-fill me-1"></i>Private</span>
                                            }
                                            else
                                            {
                                                <span><i class="bi bi-unlock me-1"></i>Public</span>
                                            }
                                        </button>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Lawyer doc</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <button class="btn btn-sm btn-outline-secondary"
                                                title="Download"
                                                @onclick="() => DownloadDocAsync(d.Id, d.FileName)">
                                            <i class="bi bi-download"></i>
                                        </button>
                                        @if (doc.UploadedByRole == "Client" && !doc.IsPrivate)
                                        {
                                            <button class="btn btn-sm @(doc.IsAvailableForDeal ? "btn-info" : "btn-outline-info")"
                                                    title="@(doc.IsAvailableForDeal ? "Remove from Hire Requests" : "Share with Hire Requests")"
                                                    disabled="@(_togglingDealShareId == doc.Id)"
                                                    @onclick="() => ToggleDealShareAsync(d)">
                                                @if (_togglingDealShareId == doc.Id)
                                                {
                                                    <span class="spinner-border spinner-border-sm"></span>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-briefcase"></i>
                                                }
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@if (_showUploadModal && _selectedCaseId > 0)
{
    <DocumentUploadComponent CaseId="_selectedCaseId"
                             IsLawyer="false"
                             OnUploadSuccess="OnUploaded"
                             OnClose="() => _showUploadModal = false" />
}

@code {
    private List<CaseSummaryDto> _cases = [];
    private List<CaseDocumentDto> _documents = [];
    private int _selectedCaseId;
    private string _docType = "";
    private bool _loadingDocs;
    private bool _showUploadModal;
    private int _togglingPrivateId;
    private int _togglingDealShareId;

    protected override async Task OnInitializedAsync()
    {
        var resp = await CaseService.GetCasesAsync(new CaseFilterDto { PageSize = 100 });
        _cases = resp?.Data?.Items ?? [];
        // If only one case, auto-select it
        if (_cases.Count == 1)
        {
            _selectedCaseId = _cases[0].Id;
            await LoadDocumentsAsync();
        }
    }

    private async Task LoadDocumentsAsync()
    {
        if (_selectedCaseId == 0)
        {
            _documents = [];
            return;
        }
        _loadingDocs = true;
        var resp = await CaseService.GetDocumentsAsync(_selectedCaseId);
        _documents = (resp?.Data ?? [])
            .Where(d => string.IsNullOrEmpty(_docType) || d.DocumentType == _docType)
            .ToList();
        _loadingDocs = false;
    }

    private async Task OnUploaded()
    {
        _showUploadModal = false;
        await LoadDocumentsAsync();
        Toast.ShowSuccess("Document uploaded.");
    }

    private async Task TogglePrivateAsync(CaseDocumentDto doc)
    {
        _togglingPrivateId = doc.Id;
        var resp = await CaseService.TogglePrivateAsync(doc.Id);
        if (resp?.Success == true)
        {
            doc.IsPrivate = resp.Data;
            // If now private, clear deal share flag locally
            if (doc.IsPrivate) doc.IsAvailableForDeal = false;
            Toast.ShowSuccess(resp.Data ? "Document is now private." : "Document is now public.");
        }
        else
        {
            Toast.ShowError(resp?.Message ?? "Failed to update visibility.");
        }
        _togglingPrivateId = 0;
    }

    private async Task ToggleDealShareAsync(CaseDocumentDto doc)
    {
        _togglingDealShareId = doc.Id;
        var resp = await CaseService.ToggleAvailableForDealAsync(doc.Id);
        if (resp?.Success == true)
        {
            doc.IsAvailableForDeal = resp.Data;
            Toast.ShowSuccess(resp.Data
                ? "Document shared with lawyers evaluating this case."
                : "Document removed from hire request sharing.");
        }
        else
        {
            Toast.ShowError(resp?.Message ?? "Failed to update sharing.");
        }
        _togglingDealShareId = 0;
    }

    private async Task DownloadDocAsync(int docId, string fileName)
    {
        try
        {
            var http = HttpClientFactory.CreateClient("secured");
            var response = await http.GetAsync($"case-documents/{docId}/download");
            if (!response.IsSuccessStatusCode) { Toast.ShowError("Download failed or access denied."); return; }
            var bytes = await response.Content.ReadAsByteArrayAsync();
            var contentType = response.Content.Headers.ContentType?.MediaType ?? "application/octet-stream";
            await JSRuntime.InvokeVoidAsync("downloadFileFromBytes", fileName, contentType, Convert.ToBase64String(bytes));
        }
        catch { Toast.ShowError("Download failed."); }
    }
}
