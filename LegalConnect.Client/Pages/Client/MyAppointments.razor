@page "/client/appointments"
@attribute [Authorize(Roles = "Client")]
@inject IAppointmentService AppointmentService
@inject ToastService Toast

<PageTitle>My Appointments – LegalConnect</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0">My Appointments</h4>
        <a href="/lawyers" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Book New
        </a>
    </div>

    <!-- Status Filter Tabs -->
    <ul class="nav nav-pills mb-4">
        @foreach (var (label, val) in _tabs)
        {
            string v = val;
            <li class="nav-item">
                <button class="nav-link @(_statusFilter == v ? "active" : "")"
                        @onclick="() => { _statusFilter = v; _ = Load(); }">
                    @label
                </button>
            </li>
        }
    </ul>

    @if (_loading)
    {
        <LoadingSpinner />
    }
    else if (_result?.Items.Count == 0)
    {
        <div class="text-center py-5">
            <i class="bi bi-calendar-x text-muted" style="font-size:3rem;"></i>
            <h5 class="mt-3">No appointments found</h5>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-3">
            @foreach (var appt in _result?.Items ?? [])
            {
                <div class="lc-card">
                    <div class="d-flex flex-wrap gap-3 align-items-start">
                        <img src="@(appt.LawyerProfilePicture ?? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(appt.LawyerName)}&size=48&background=1a56db&color=fff")"
                             class="rounded-circle" style="width:52px;height:52px;object-fit:cover;" alt="" />
                        <div class="flex-grow-1">
                            <h6 class="fw-semibold mb-1">@appt.LawyerName</h6>
                            <div class="text-muted small">
                                <i class="bi bi-calendar me-1"></i>
                                @appt.AppointmentDate.ToString("dddd, MMMM dd, yyyy")
                                &nbsp;·&nbsp;
                                @DateTime.Today.Add(appt.StartTime).ToString("hh:mm tt")
                                – @DateTime.Today.Add(appt.EndTime).ToString("hh:mm tt")
                            </div>
                            @if (!string.IsNullOrWhiteSpace(appt.Notes))
                            {
                                <p class="text-muted small mb-0 mt-1">@appt.Notes</p>
                            }
                        </div>

                        <div class="text-end">
                            <span class="badge @StatusBadge(appt.Status) mb-1 d-block">@appt.Status</span>
                            <div class="fw-bold text-primary small">৳@appt.TotalAmount.ToString("N0")</div>
                        </div>
                    </div>

                    <!-- Actions -->
                    @if (appt.Status is AppointmentStatus.Pending or AppointmentStatus.Confirmed)
                    {
                        <div class="mt-3 pt-3 border-top d-flex gap-2 justify-content-end">
                            <a href="/lawyers/@appt.LawyerId" class="btn btn-sm btn-outline-primary">
                                View Lawyer
                            </a>
                            <button class="btn btn-sm btn-outline-danger"
                                    @onclick="() => PromptCancel(appt)">
                                Cancel
                            </button>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (_result is { TotalPages: > 1 })
        {
            <div class="mt-4">
                <Pagination CurrentPage="_result.PageNumber"
                            TotalPages="_result.TotalPages"
                            TotalItems="_result.TotalCount"
                            OnPageChanged="p => { _page = p; _ = Load(); }" />
            </div>
        }
    }
</div>

<!-- Cancel Modal -->
<ConfirmationModal @ref="_cancelModal"
                   Title="Cancel Appointment"
                   Message="Are you sure you want to cancel this appointment? This action may be irreversible."
                   ConfirmText="Yes, Cancel"
                   ConfirmButtonClass="btn-danger"
                   OnConfirmed="ConfirmCancel" />

@code {
    private PagedResult<AppointmentDto>? _result;
    private bool _loading = true;
    private int _page = 1;
    private string _statusFilter = "";
    private AppointmentDto? _toCancel;
    private ConfirmationModal? _cancelModal;

    private static readonly (string, string)[] _tabs =
    [
        ("All", ""), ("Upcoming", "confirmed"),
        ("Pending", "pending"), ("Completed", "completed"), ("Cancelled", "cancelled")
    ];

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        _loading = true;
        _result  = await AppointmentService.GetMyAppointmentsAsync(_page);
        _loading = false;
    }

    private void PromptCancel(AppointmentDto appt)
    {
        _toCancel = appt;
        _cancelModal?.Show();
    }

    private async Task ConfirmCancel()
    {
        if (_toCancel is null) return;
        var (ok, err) = await AppointmentService.CancelAppointmentAsync(
            _toCancel.Id, new CancelAppointmentDto { Reason = "Client cancelled" });

        if (ok) { Toast.ShowSuccess("Appointment cancelled."); await Load(); }
        else    { Toast.ShowError(err ?? "Cancellation failed."); }
    }

    private static string StatusBadge(AppointmentStatus s) => s switch
    {
        AppointmentStatus.Confirmed => "bg-success",
        AppointmentStatus.Pending   => "bg-warning text-dark",
        AppointmentStatus.Cancelled => "bg-danger",
        AppointmentStatus.Completed => "bg-secondary",
        _                           => "bg-light text-dark"
    };
}
