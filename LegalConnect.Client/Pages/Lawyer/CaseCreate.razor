@page "/lawyer/cases/create"
@using LegalConnect.Client.Models.Cases
@using LegalConnect.Client.Services
@attribute [Authorize(Roles = "Lawyer")]
@inject ICaseService CaseService
@inject ILawyerClientService LawyerClientService
@inject ToastService Toast
@inject NavigationManager Nav

<PageTitle>New Case — LawCity</PageTitle>

<div class="container py-4" style="max-width: 800px;">
    <div class="d-flex align-items-center mb-4">
        <a href="/lawyer/cases" class="btn btn-outline-secondary btn-sm me-3">
            <i class="bi bi-arrow-left"></i>
        </a>
        <div>
            <h2 class="mb-0"><i class="bi bi-folder-plus text-primary me-2"></i>New Case</h2>
            <p class="text-muted mb-0">Create a new case for a client</p>
        </div>
    </div>

    <EditForm Model="_dto" OnValidSubmit="SubmitAsync">
        <DataAnnotationsValidator />

        <div class="card shadow-sm mb-4">
            <div class="card-header bg-light">
                <h6 class="mb-0"><i class="bi bi-info-circle me-2"></i>Case Information</h6>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-8">
                        <label class="form-label">Case Title <span class="text-danger">*</span></label>
                        <InputText class="form-control" @bind-Value="_dto.CaseTitle"
                                   placeholder="e.g. Property Dispute - Singh vs Kumar" />
                        <ValidationMessage For="@(() => _dto.CaseTitle)" class="text-danger small" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Case Number</label>
                        <InputText class="form-control" @bind-Value="_dto.CaseNumber"
                                   placeholder="e.g. 2024/CIV/001" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Case Type <span class="text-danger">*</span></label>
                        <InputSelect class="form-select" @bind-Value="_dto.CaseType">
                            <option value="">Select type...</option>
                            <option>Criminal</option>
                            <option>Civil</option>
                            <option>Family</option>
                            <option>Property</option>
                            <option>Corporate</option>
                            <option>Labour</option>
                            <option>Constitutional</option>
                            <option>Other</option>
                        </InputSelect>
                        <ValidationMessage For="@(() => _dto.CaseType)" class="text-danger small" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Court <span class="text-danger">*</span></label>
                        <InputText class="form-control" @bind-Value="_dto.Court"
                                   placeholder="e.g. District Court, Mumbai" />
                        <ValidationMessage For="@(() => _dto.Court)" class="text-danger small" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Filing Date</label>
                        <InputDate class="form-control" @bind-Value="_dto.FilingDate" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Next Hearing Date</label>
                        <InputDate class="form-control" @bind-Value="_dto.NextHearingDate" />
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header bg-light">
                <h6 class="mb-0"><i class="bi bi-person me-2"></i>Client</h6>
            </div>
            <div class="card-body">
                @if (_myClients == null)
                {
                    <div class="text-muted"><i class="spinner-border spinner-border-sm me-2"></i>Loading clients...</div>
                }
                else if (_myClients.Count == 0)
                {
                    <div class="alert alert-warning mb-0">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        No clients found. <a href="/lawyer/my-clients">Add clients</a> first.
                    </div>
                }
                else
                {
                    <label class="form-label">Select Client <span class="text-danger">*</span></label>
                    <select class="form-select" @bind="_selectedClientId">
                        <option value="0">— Select a client —</option>
                        @foreach (var c in _myClients)
                        {
                            <option value="@c.ClientProfileId">@c.ClientFullName (@c.ClientEmail)</option>
                        }
                    </select>
                }
                <ValidationMessage For="@(() => _dto.ClientProfileId)" class="text-danger small" />
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header bg-light">
                <h6 class="mb-0"><i class="bi bi-card-text me-2"></i>Description</h6>
            </div>
            <div class="card-body">
                <InputTextArea class="form-control" rows="5" @bind-Value="_dto.Description"
                               placeholder="Describe the case details, background, and objectives..." />
                <ValidationMessage For="@(() => _dto.Description)" class="text-danger small" />
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_errorMsg))
        {
            <div class="alert alert-danger"><i class="bi bi-exclamation-circle me-2"></i>@_errorMsg</div>
        }

        <div class="d-flex gap-2 justify-content-end">
            <a href="/lawyer/cases" class="btn btn-outline-secondary">Cancel</a>
            <button type="submit" class="btn btn-primary" disabled="@_submitting">
                @if (_submitting)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                }
                <i class="bi bi-folder-plus me-2"></i>Create Case
            </button>
        </div>
    </EditForm>
</div>

@code {
    private CreateCaseDto _dto = new() { FilingDate = DateTime.Today };
    private List<LawyerClientDto>? _myClients;
    private int _selectedClientId;
    private bool _submitting;
    private string _errorMsg = "";

    protected override async Task OnInitializedAsync()
    {
        var resp = await LawyerClientService.GetMyClientsAsync(
            new LawyerClientFilterDto { IsActive = true, PageSize = 100 });
        _myClients = resp?.Data?.Items ?? [];
    }

    private async Task SubmitAsync()
    {
        _errorMsg = "";
        if (_selectedClientId == 0)
        {
            _errorMsg = "Please select a client.";
            return;
        }

        _dto.ClientProfileId = _selectedClientId;
        // Link to LawyerClient relationship if it exists
        var lc = _myClients?.FirstOrDefault(c => c.ClientProfileId == _selectedClientId);
        if (lc != null) _dto.LawyerClientId = lc.Id;

        _submitting = true;
        var resp = await CaseService.CreateCaseAsync(_dto);
        if (resp?.Success == true)
        {
            Toast.ShowSuccess("Case created successfully!");
            Nav.NavigateTo($"/lawyer/cases/{resp.Data!.Id}");
        }
        else
        {
            _errorMsg = resp?.Message ?? "Failed to create case.";
        }
        _submitting = false;
    }
}
