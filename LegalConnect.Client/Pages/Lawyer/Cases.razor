@page "/lawyer/cases"
@using LegalConnect.Client.Models.Cases
@using LegalConnect.Client.Services
@using LegalConnect.Client.Components
@attribute [Authorize(Roles = "Lawyer")]
@inject ICaseService CaseService
@inject ToastService Toast
@inject NavigationManager Nav

<PageTitle>Cases — LegalConnect</PageTitle>

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0"><i class="bi bi-folder2-open text-primary me-2"></i>Cases</h2>
            <p class="text-muted mb-0">Manage all client cases</p>
        </div>
        <a href="/lawyer/cases/create" class="btn btn-primary">
            <i class="bi bi-folder-plus me-2"></i>New Case
        </a>
    </div>

    <!-- Filter Bar -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input class="form-control" placeholder="Search cases..."
                               @bind="_filter.SearchTerm" @bind:event="oninput" @onkeyup="OnSearchKeyUp" />
                    </div>
                </div>
                <div class="col-md-2">
                    <select class="form-select" @bind="_statusStr">
                        <option value="">All Statuses</option>
                        <option value="Open">Open</option>
                        <option value="InProgress">In Progress</option>
                        <option value="OnHold">On Hold</option>
                        <option value="Closed">Closed</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <input class="form-control" placeholder="Case Type" @bind="_filter.CaseType" />
                </div>
                <div class="col-md-2">
                    <select class="form-select" @bind="_filter.SortBy">
                        <option value="modifiedDate">Last Modified</option>
                        <option value="title">Title</option>
                        <option value="filingDate">Filing Date</option>
                        <option value="status">Status</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-outline-primary w-100" @onclick="LoadCasesAsync">
                        <i class="bi bi-funnel me-1"></i>Filter
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Content -->
    @if (_loading)
    {
        <LoadingSpinner Message="Loading cases..." />
    }
    else if (_cases?.Items.Count == 0)
    {
        <div class="text-center py-5">
            <i class="bi bi-folder-x display-1 text-muted"></i>
            <h4 class="mt-3 text-muted">No cases found</h4>
            <p class="text-muted">Create your first case to get started.</p>
            <a href="/lawyer/cases/create" class="btn btn-primary">
                <i class="bi bi-folder-plus me-2"></i>Create Case
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var c in _cases!.Items)
            {
                <div class="col-xl-4 col-lg-6">
                    <CaseCard Case="c"
                              OnViewDetails="@(() => Nav.NavigateTo($"/lawyer/cases/{c.Id}"))"
                              OnEdit="@(() => Nav.NavigateTo($"/lawyer/cases/{c.Id}/edit"))"
                              OnDelete="@(() => ConfirmDelete(c))" />
                </div>
            }
        </div>

        @if (_cases!.TotalPages > 1)
        {
            <Pagination CurrentPage="_cases.PageNumber"
                        TotalPages="_cases.TotalPages"
                        OnPageChange="OnPageChange" />
        }
    }
</div>

@if (_deleteCase != null)
{
    <ConfirmationModal Title="Delete Case"
                       Message="@($"Permanently delete case '{_deleteCase.CaseTitle}'? This cannot be undone.")"
                       ConfirmText="Delete"
                       ConfirmClass="btn-danger"
                       OnConfirm="ExecuteDeleteAsync"
                       OnCancel="@(() => _deleteCase = null)" />
}

@code {
    [SupplyParameterFromQuery(Name = "clientId")] public int? ClientId { get; set; }

    private PagedResult<CaseSummaryDto>? _cases;
    private CaseFilterDto _filter = new();
    private bool _loading = true;
    private string _statusStr = "";
    private CaseSummaryDto? _deleteCase;

    protected override async Task OnInitializedAsync()
    {
        if (ClientId.HasValue) _filter.ClientProfileId = ClientId;
        await LoadCasesAsync();
    }

    private async Task LoadCasesAsync()
    {
        _loading = true;
        _filter.Status = string.IsNullOrEmpty(_statusStr) ? null : Enum.Parse<CaseStatus>(_statusStr);
        var resp = await CaseService.GetCasesAsync(_filter);
        _cases = resp?.Data ?? new PagedResult<CaseSummaryDto>();
        _loading = false;
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await LoadCasesAsync();
    }

    private async Task OnPageChange(int page)
    {
        _filter.PageNumber = page;
        await LoadCasesAsync();
    }

    private void ConfirmDelete(CaseSummaryDto c) => _deleteCase = c;

    private async Task ExecuteDeleteAsync()
    {
        var resp = await CaseService.DeleteCaseAsync(_deleteCase!.Id);
        if (resp?.Success == true) { Toast.ShowSuccess("Case deleted."); await LoadCasesAsync(); }
        else Toast.ShowError(resp?.Message ?? "Failed.");
        _deleteCase = null;
    }
}
