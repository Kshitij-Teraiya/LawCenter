@page "/lawyer/invoice-settings"
@attribute [Authorize(Roles = "Lawyer")]
@using LegalConnect.Client.Models.Deals
@inject IDealService DealService
@inject ToastService Toast

<PageTitle>Invoice Settings &mdash; LawCity</PageTitle>

<div class="container py-4" style="max-width: 720px;">
    <div class="d-flex align-items-center gap-2 mb-4">
        <a href="/lawyer/hire-requests" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left"></i></a>
        <div>
            <h4 class="mb-0">Invoice Settings</h4>
            <p class="text-muted small mb-0">Firm details printed on every invoice</p>
        </div>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5"><span class="spinner-border text-primary"></span></div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <h6 class="mb-0"><i class="bi bi-building me-2"></i>Firm &amp; Contact Information</h6>
            </div>
            <div class="card-body">
                <EditForm Model="_model" OnValidSubmit="SaveAsync">
                    <DataAnnotationsValidator />

                    <div class="row g-3">
                        <!-- Firm Name -->
                        <div class="col-12">
                            <label class="form-label fw-semibold small">Firm / Practice Name</label>
                            <InputText class="form-control" @bind-Value="_model.FirmName" placeholder="e.g. Sharma & Associates" />
                        </div>

                        <!-- Address -->
                        <div class="col-12">
                            <label class="form-label fw-semibold small">Firm Address</label>
                            <InputText class="form-control" @bind-Value="_model.FirmAddress" placeholder="Street / Building" />
                        </div>

                        <!-- City / State / Country -->
                        <div class="col-4">
                            <label class="form-label fw-semibold small">City</label>
                            <InputText class="form-control" @bind-Value="_model.City" placeholder="City" />
                        </div>
                        <div class="col-4">
                            <label class="form-label fw-semibold small">State</label>
                            <InputText class="form-control" @bind-Value="_model.State" placeholder="State" />
                        </div>
                        <div class="col-4">
                            <label class="form-label fw-semibold small">Postal Code</label>
                            <InputText class="form-control" @bind-Value="_model.PostalCode" placeholder="000000" />
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-semibold small">Country</label>
                            <InputText class="form-control" @bind-Value="_model.Country" placeholder="India" />
                        </div>

                        <!-- GST / Tax -->
                        <div class="col-6">
                            <label class="form-label fw-semibold small">GST Number</label>
                            <InputText class="form-control" @bind-Value="_model.GSTNumber" placeholder="22AAAAA0000A1Z5" />
                        </div>

                        <!-- Phone / Email / Website -->
                        <div class="col-6">
                            <label class="form-label fw-semibold small">Phone</label>
                            <InputText class="form-control" @bind-Value="_model.Phone" placeholder="+91 98765 43210" />
                        </div>
                        <div class="col-7">
                            <label class="form-label fw-semibold small">Email</label>
                            <InputText class="form-control" @bind-Value="_model.Email" placeholder="lawyer@firm.com" />
                            <ValidationMessage For="() => _model.Email" />
                        </div>
                        <div class="col-5">
                            <label class="form-label fw-semibold small">Website</label>
                            <InputText class="form-control" @bind-Value="_model.Website" placeholder="https://firm.com" />
                            <ValidationMessage For="() => _model.Website" />
                        </div>
                    </div>

                    <hr />
                    <h6 class="mb-3"><i class="bi bi-bank me-2"></i>Bank Details</h6>
                    <div class="mb-3">
                        <InputTextArea class="form-control" rows="3" @bind-Value="_model.BankDetails"
                                       placeholder="Bank Name: XYZ Bank&#10;A/C No: 0000000000&#10;IFSC: XYZB0001234" />
                    </div>

                    <hr />
                    <h6 class="mb-3"><i class="bi bi-file-text me-2"></i>Invoice Footer</h6>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Notes for Invoice</label>
                        <InputTextArea class="form-control" rows="2" @bind-Value="_model.NotesForInvoice"
                                       placeholder="e.g. Payment due within 30 days of invoice date." />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Terms &amp; Conditions</label>
                        <InputTextArea class="form-control" rows="3" @bind-Value="_model.TermsAndConditions"
                                       placeholder="1. Payment terms...&#10;2. Dispute resolution..." />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary" disabled="@_saving">
                            @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            <i class="bi bi-floppy me-1"></i>Save Settings
                        </button>
                        @if (_saved)
                        {
                            <span class="text-success small align-self-center"><i class="bi bi-check-circle me-1"></i>Saved!</span>
                        }
                    </div>
                </EditForm>
            </div>
        </div>

        <!-- Preview hint -->
        <div class="alert alert-info mt-3 small">
            <i class="bi bi-info-circle me-1"></i>
            These details will appear on all future invoices. Use <strong>Print / Download PDF</strong>
            on any invoice to generate a professional PDF via your browser.
        </div>
    }
</div>

@code {
    private UpsertLawyerInvoiceSettingsDto _model = new();
    private bool _loading = true;
    private bool _saving;
    private bool _saved;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        var resp = await DealService.GetInvoiceSettingsAsync();
        if (resp?.Data != null)
        {
            var s = resp.Data;
            _model = new UpsertLawyerInvoiceSettingsDto
            {
                FirmName = s.FirmName,
                FirmAddress = s.FirmAddress,
                City = s.City,
                State = s.State,
                Country = s.Country,
                PostalCode = s.PostalCode,
                GSTNumber = s.GSTNumber,
                Phone = s.Phone,
                Email = s.Email,
                Website = s.Website,
                BankDetails = s.BankDetails,
                NotesForInvoice = s.NotesForInvoice,
                TermsAndConditions = s.TermsAndConditions
            };
        }
        _loading = false;
    }

    private async Task SaveAsync()
    {
        _saving = true;
        _saved = false;
        var resp = await DealService.UpsertInvoiceSettingsAsync(_model);
        if (resp?.Success == true)
        {
            _saved = true;
            Toast.ShowSuccess("Invoice settings saved!");
        }
        else { Toast.ShowError(resp?.Message ?? "Failed to save."); }
        _saving = false;
    }
}
