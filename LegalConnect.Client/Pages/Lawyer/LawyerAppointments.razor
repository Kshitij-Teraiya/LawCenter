@page "/lawyer/appointments"
@attribute [Authorize(Roles = "Lawyer")]
@inject IAppointmentService AppointmentService
@inject ToastService Toast

<PageTitle>My Appointments – LegalConnect</PageTitle>

<div class="container-fluid">
    <h4 class="fw-bold mb-4">
        <i class="bi bi-calendar3 me-2 text-primary"></i>Appointment Calendar
    </h4>

    <!-- Date Range Filter -->
    <div class="lc-card mb-4">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label fw-medium">From</label>
                <input type="date" class="form-control" @bind="_from" />
            </div>
            <div class="col-md-3">
                <label class="form-label fw-medium">To</label>
                <input type="date" class="form-control" @bind="_to" />
            </div>
            <div class="col-md-2">
                <button class="btn btn-primary w-100" @onclick="Load">
                    <i class="bi bi-search me-1"></i>Search
                </button>
            </div>
        </div>
    </div>

    @if (_loading)
    {
        <LoadingSpinner />
    }
    else if (_appointments.Count == 0)
    {
        <div class="text-center py-5">
            <i class="bi bi-calendar-x text-muted" style="font-size:3rem;"></i>
            <h5 class="mt-3">No appointments in this range</h5>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-3">
            @foreach (var appt in _appointments)
            {
                var a = appt;
                <div class="lc-card">
                    <div class="d-flex flex-wrap gap-3 align-items-center">
                        <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                            <i class="bi bi-person"></i>
                        </div>
                        <div class="flex-grow-1">
                            <h6 class="fw-semibold mb-0">@appt.ClientName</h6>
                            <div class="text-muted small">
                                @appt.AppointmentDate.ToString("dddd, MMMM dd, yyyy")
                                &nbsp;·&nbsp;
                                @DateTime.Today.Add(appt.StartTime).ToString("hh:mm tt")
                                – @DateTime.Today.Add(appt.EndTime).ToString("hh:mm tt")
                            </div>
                            @if (!string.IsNullOrWhiteSpace(appt.Notes))
                            {
                                <p class="text-muted small mb-0 mt-1 fst-italic">"@appt.Notes"</p>
                            }
                        </div>

                        <div class="text-end">
                            <div class="fw-bold text-primary">৳@appt.ConsultationFee.ToString("N0")</div>
                            <span class="badge @StatusBadge(appt.Status)">@appt.Status</span>
                        </div>

                        @if (appt.Status == AppointmentStatus.Pending)
                        {
                            <div class="d-flex gap-2">
                                <button class="btn btn-sm btn-success"
                                        @onclick="() => Confirm(a)">
                                    <i class="bi bi-check-lg me-1"></i>Confirm
                                </button>
                            </div>
                        }
                        else if (appt.Status == AppointmentStatus.Confirmed)
                        {
                            <button class="btn btn-sm btn-outline-success"
                                    @onclick="() => Complete(a)">
                                <i class="bi bi-check-circle me-1"></i>Mark Complete
                            </button>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<AppointmentDto> _appointments = [];
    private bool _loading = true;
    private DateTime _from = DateTime.Today;
    private DateTime _to   = DateTime.Today.AddDays(30);

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        _loading = true;
        _appointments = await AppointmentService.GetLawyerAppointmentsAsync(_from, _to);
        _loading = false;
    }

    private async Task Confirm(AppointmentDto appt)
    {
        var (ok, err) = await AppointmentService.ConfirmAppointmentAsync(appt.Id);
        if (ok) { Toast.ShowSuccess("Appointment confirmed!"); await Load(); }
        else    Toast.ShowError(err ?? "Failed.");
    }

    private async Task Complete(AppointmentDto appt)
    {
        var (ok, err) = await AppointmentService.CompleteAppointmentAsync(appt.Id);
        if (ok) { Toast.ShowSuccess("Marked as completed!"); await Load(); }
        else    Toast.ShowError(err ?? "Failed.");
    }

    private static string StatusBadge(AppointmentStatus s) => s switch
    {
        AppointmentStatus.Confirmed => "bg-success",
        AppointmentStatus.Pending   => "bg-warning text-dark",
        AppointmentStatus.Completed => "bg-secondary",
        _                           => "bg-danger"
    };
}
