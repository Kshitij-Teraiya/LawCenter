@page "/lawyer/availability"
@attribute [Authorize(Roles = "Lawyer")]
@inject ILawyerAvailabilityService AvailabilityService
@inject ToastService Toast

<PageTitle>Manage Availability &ndash; LawCity</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-0">Manage Availability</h4>
            <p class="text-muted mb-0 small">Configure your session duration, working hours, and holidays</p>
        </div>
    </div>

    @if (_loading)
    {
        <LoadingSpinner />
    }
    else
    {
        <ul class="nav nav-tabs mb-4">
            <li class="nav-item">
                <button class='nav-link @(_activeTab == "config" ? "active" : "")' @onclick='() => _activeTab = "config"'>
                    <i class="bi bi-clock me-1"></i>Session
                </button>
            </li>
            <li class="nav-item">
                <button class='nav-link @(_activeTab == "hours" ? "active" : "")' @onclick='() => _activeTab = "hours"'>
                    <i class="bi bi-calendar-week me-1"></i>Working Hours
                </button>
            </li>
            <li class="nav-item">
                <button class='nav-link @(_activeTab == "blackout" ? "active" : "")' @onclick='() => _activeTab = "blackout"'>
                    <i class="bi bi-slash-circle me-1"></i>Blackout Blocks
                </button>
            </li>
            <li class="nav-item">
                <button class='nav-link @(_activeTab == "personal" ? "active" : "")' @onclick='() => _activeTab = "personal"'>
                    <i class="bi bi-calendar-x me-1"></i>Personal Holidays
                </button>
            </li>
            <li class="nav-item">
                <button class='nav-link @(_activeTab == "master" ? "active" : "")' @onclick='() => _activeTab = "master"'>
                    <i class="bi bi-flag me-1"></i>Public Holidays
                </button>
            </li>
        </ul>

        @if (_activeTab == "config" && _config != null)
        {
            <div class="card border-0 shadow-sm p-4" style="max-width:500px;">
                <h6 class="fw-semibold mb-3">Session Duration &amp; Buffer Time</h6>
                <div class="mb-3">
                    <label class="form-label">Session Duration</label>
                    <select class="form-select" @bind="_config.SessionDurationMinutes">
                        <option value="15">15 minutes</option>
                        <option value="30">30 minutes</option>
                        <option value="45">45 minutes</option>
                        <option value="60">60 minutes (1 hour)</option>
                    </select>
                </div>
                <div class="mb-4">
                    <label class="form-label">Buffer Time Between Sessions</label>
                    <select class="form-select" @bind="_config.BufferTimeMinutes">
                        <option value="0">No buffer</option>
                        <option value="10">10 minutes</option>
                        <option value="15">15 minutes</option>
                        <option value="30">30 minutes</option>
                        <option value="60">60 minutes</option>
                    </select>
                    <div class="form-text">Time gap between consecutive appointments.</div>
                </div>
                <button class="btn btn-primary" @onclick="SaveConfiguration" disabled="@_saving">
                    @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    Save Configuration
                </button>
            </div>
        }

        @if (_activeTab == "hours")
        {
            <div class="card border-0 shadow-sm">
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Day</th>
                                <th>Working?</th>
                                <th>Start</th>
                                <th>End</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var wh in _workingHours)
                            {
                                <tr>
                                    <td class="align-middle fw-semibold">@wh.DayName</td>
                                    <td class="align-middle">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" checked="@wh.IsWorking"
                                                   @onchange="e => ToggleWorkingDay(wh, (bool)(e.Value ?? false))" />
                                        </div>
                                    </td>
                                    <td class="align-middle">
                                        @if (wh.IsWorking)
                                        {
                                            <input type="time" class="form-control form-control-sm" style="width:120px;"
                                                   value="@FormatTime(wh.StartTime)"
                                                   @onchange="e => UpdateStartTime(wh, e.Value?.ToString())" />
                                        }
                                        else { <span class="text-muted">&mdash;</span> }
                                    </td>
                                    <td class="align-middle">
                                        @if (wh.IsWorking)
                                        {
                                            <input type="time" class="form-control form-control-sm" style="width:120px;"
                                                   value="@FormatTime(wh.EndTime)"
                                                   @onchange="e => UpdateEndTime(wh, e.Value?.ToString())" />
                                        }
                                        else { <span class="text-muted">&mdash;</span> }
                                    </td>
                                    <td class="align-middle">
                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => SaveWorkingHours(wh)">
                                            Save
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        @if (_activeTab == "blackout")
        {
            <div class="row g-4">
                <div class="col-lg-5">
                    <div class="card border-0 shadow-sm p-4">
                        <h6 class="fw-semibold mb-3">Add Blackout Block</h6>
                        <div class="mb-2">
                            <label class="form-label small">Day of Week</label>
                            <select class="form-select form-select-sm" @bind="_newBlock.DayOfWeek">
                                <option value="0">Sunday</option>
                                <option value="1">Monday</option>
                                <option value="2">Tuesday</option>
                                <option value="3">Wednesday</option>
                                <option value="4">Thursday</option>
                                <option value="5">Friday</option>
                                <option value="6">Saturday</option>
                            </select>
                        </div>
                        <div class="mb-2">
                            <label class="form-label small">Start Time</label>
                            <input type="time" class="form-control form-control-sm"
                                   @onchange="e => _newBlock.StartTime = ParseTime(e.Value?.ToString())" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label small">End Time</label>
                            <input type="time" class="form-control form-control-sm"
                                   @onchange="e => _newBlock.EndTime = ParseTime(e.Value?.ToString())" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label small">Reason</label>
                            <input class="form-control form-control-sm" @bind="_newBlock.Reason" placeholder="e.g. Team meeting" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label small">Recurrence</label>
                            <select class="form-select form-select-sm" @bind="_newBlock.RecurringPattern">
                                <option value="None">One-time</option>
                                <option value="Weekly">Every week</option>
                                <option value="MonthlyDate">Monthly (same date)</option>
                                <option value="Yearly">Yearly</option>
                            </select>
                        </div>
                        <button class="btn btn-primary btn-sm" @onclick="AddBlackoutBlock" disabled="@_saving">
                            @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Add Block
                        </button>
                    </div>
                </div>
                <div class="col-lg-7">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body p-0">
                            @if (!_blackoutBlocks.Any())
                            {
                                <p class="text-muted p-4 mb-0">No blackout blocks configured.</p>
                            }
                            else
                            {
                                <table class="table table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Day</th>
                                            <th>Time</th>
                                            <th>Reason</th>
                                            <th>Recurrence</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var block in _blackoutBlocks)
                                        {
                                            <tr>
                                                <td>@block.DayName</td>
                                                <td>@block.TimeRange</td>
                                                <td>@block.Reason</td>
                                                <td>@block.RecurringPattern</td>
                                                <td>
                                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteBlackoutBlock(block.Id)">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (_activeTab == "personal")
        {
            <div class="row g-4">
                <div class="col-lg-4">
                    <div class="card border-0 shadow-sm p-4">
                        <h6 class="fw-semibold mb-3">Add Personal Holiday</h6>
                        <div class="mb-2">
                            <label class="form-label small">Date</label>
                            <input type="date" class="form-control form-control-sm"
                                   @onchange="e => SetHolidayDate(e.Value?.ToString())" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label small">Reason</label>
                            <input class="form-control form-control-sm" @bind="_newHoliday.Reason" placeholder="e.g. Vacation" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label small">Recurrence</label>
                            <select class="form-select form-select-sm" @bind="_newHoliday.RecurringPattern">
                                <option value="None">One-time</option>
                                <option value="Weekly">Every week</option>
                                <option value="MonthlyDate">Monthly (same date)</option>
                                <option value="Yearly">Yearly</option>
                            </select>
                        </div>
                        <button class="btn btn-primary btn-sm" @onclick="AddPersonalHoliday" disabled="@_saving">
                            @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Add Holiday
                        </button>
                    </div>
                </div>
                <div class="col-lg-8">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body p-0">
                            @if (!_personalHolidays.Any())
                            {
                                <p class="text-muted p-4 mb-0">No personal holidays configured.</p>
                            }
                            else
                            {
                                <table class="table table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Date</th>
                                            <th>Reason</th>
                                            <th>Recurrence</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var h in _personalHolidays)
                                        {
                                            <tr>
                                                <td>@h.HolidayDate.ToString("dd MMM yyyy")</td>
                                                <td>@h.Reason</td>
                                                <td>@h.RecurringPattern</td>
                                                <td>
                                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeletePersonalHoliday(h.Id)">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (_activeTab == "master")
        {
            <div class="card border-0 shadow-sm">
                <div class="card-body p-0">
                    @if (!_holidayPreferences.Any())
                    {
                        <p class="text-muted p-4 mb-0">No public holidays available. Ask admin to add them.</p>
                    }
                    else
                    {
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Holiday</th>
                                    <th>Date</th>
                                    <th>Recurring</th>
                                    <th>Observe?</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var pref in _holidayPreferences)
                                {
                                    <tr>
                                        <td class="fw-semibold">@pref.HolidayName</td>
                                        <td>@pref.HolidayDate.ToString("dd MMM yyyy")</td>
                                        <td>@(pref.AppliesYearly ? "Yearly" : "One-time")</td>
                                        <td>
                                            <div class="form-check form-switch">
                                                <input class="form-check-input" type="checkbox" checked="@pref.IsEnabled"
                                                       @onchange="e => ToggleHolidayPreference(pref, (bool)(e.Value ?? false))" />
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        }
    }
</div>

@code {
    private string _activeTab = "config";
    private bool _loading = true;
    private bool _saving;

    private Models.TimeSlots.TimeSlotConfigurationModel? _config;
    private List<Models.TimeSlots.WorkingHoursModel> _workingHours = [];
    private List<Models.TimeSlots.BlackoutBlockModel> _blackoutBlocks = [];
    private List<Models.TimeSlots.PersonalHolidayModel> _personalHolidays = [];
    private List<Models.TimeSlots.HolidayPreferenceModel> _holidayPreferences = [];

    private Models.TimeSlots.CreateBlackoutBlockModel _newBlock = new();
    private Models.TimeSlots.CreatePersonalHolidayModel _newHoliday = new();

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(
            LoadConfig(),
            LoadWorkingHours(),
            LoadBlackoutBlocks(),
            LoadPersonalHolidays(),
            LoadHolidayPreferences()
        );
        _loading = false;
    }

    private async Task LoadConfig() => _config = await AvailabilityService.GetConfigurationAsync() ?? new();
    private async Task LoadWorkingHours() => _workingHours = await AvailabilityService.GetWorkingHoursAsync();
    private async Task LoadBlackoutBlocks() => _blackoutBlocks = await AvailabilityService.GetBlackoutBlocksAsync();
    private async Task LoadPersonalHolidays() => _personalHolidays = await AvailabilityService.GetPersonalHolidaysAsync();
    private async Task LoadHolidayPreferences() => _holidayPreferences = await AvailabilityService.GetHolidayPreferencesAsync();

    private async Task SaveConfiguration()
    {
        if (_config == null) return;
        _saving = true;
        var ok = await AvailabilityService.UpdateConfigurationAsync(new()
        {
            SessionDurationMinutes = _config.SessionDurationMinutes,
            BufferTimeMinutes = _config.BufferTimeMinutes
        });
        _saving = false;
        if (ok) Toast.ShowSuccess("Configuration saved.");
        else Toast.ShowError("Failed to save configuration.");
    }

    private void ToggleWorkingDay(Models.TimeSlots.WorkingHoursModel wh, bool value) => wh.IsWorking = value;

    private void UpdateStartTime(Models.TimeSlots.WorkingHoursModel wh, string? value)
    {
        if (TimeSpan.TryParse(value, out var ts)) wh.StartTime = ts;
    }

    private void UpdateEndTime(Models.TimeSlots.WorkingHoursModel wh, string? value)
    {
        if (TimeSpan.TryParse(value, out var ts)) wh.EndTime = ts;
    }

    private async Task SaveWorkingHours(Models.TimeSlots.WorkingHoursModel wh)
    {
        var ok = await AvailabilityService.UpdateWorkingHoursAsync(wh.DayOfWeek, new()
        {
            StartTime = wh.StartTime,
            EndTime = wh.EndTime,
            IsWorking = wh.IsWorking
        });
        if (ok) Toast.ShowSuccess($"{wh.DayName} hours saved.");
        else Toast.ShowError("Failed to save working hours.");
    }

    private async Task AddBlackoutBlock()
    {
        _saving = true;
        var ok = await AvailabilityService.CreateBlackoutBlockAsync(_newBlock);
        if (ok)
        {
            await LoadBlackoutBlocks();
            _newBlock = new();
            Toast.ShowSuccess("Blackout block added.");
        }
        else
        {
            Toast.ShowError("Failed to add blackout block.");
        }
        _saving = false;
    }

    private async Task DeleteBlackoutBlock(int id)
    {
        var ok = await AvailabilityService.DeleteBlackoutBlockAsync(id);
        if (ok) { await LoadBlackoutBlocks(); Toast.ShowSuccess("Block removed."); }
    }

    private void SetHolidayDate(string? value)
    {
        if (DateTime.TryParse(value, out var d)) _newHoliday.HolidayDate = d;
    }

    private async Task AddPersonalHoliday()
    {
        _saving = true;
        var ok = await AvailabilityService.CreatePersonalHolidayAsync(_newHoliday);
        if (ok)
        {
            await LoadPersonalHolidays();
            _newHoliday = new();
            Toast.ShowSuccess("Personal holiday added.");
        }
        else
        {
            Toast.ShowError("Failed to add holiday.");
        }
        _saving = false;
    }

    private async Task DeletePersonalHoliday(int id)
    {
        var ok = await AvailabilityService.DeletePersonalHolidayAsync(id);
        if (ok) { await LoadPersonalHolidays(); Toast.ShowSuccess("Holiday removed."); }
    }

    private async Task ToggleHolidayPreference(Models.TimeSlots.HolidayPreferenceModel pref, bool value)
    {
        pref.IsEnabled = value;
        await AvailabilityService.SetHolidayPreferenceAsync(pref.MasterHolidayId, value);
        if (value) Toast.ShowSuccess($"{pref.HolidayName} enabled.");
        else Toast.ShowInfo($"{pref.HolidayName} disabled.");
    }

    private static string FormatTime(TimeSpan t) => t.ToString(@"hh\:mm");
    private static TimeSpan ParseTime(string? s) => TimeSpan.TryParse(s, out var ts) ? ts : TimeSpan.Zero;
}
