@page "/lawyer/dashboard"
@attribute [Authorize(Roles = "Lawyer")]
@inject ILawyerService LawyerService
@inject IAppointmentService AppointmentService
@inject IAuthService AuthService

<PageTitle>Lawyer Dashboard – LegalConnect</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-0">Lawyer Dashboard</h4>
            <p class="text-muted mb-0 small">@_name</p>
        </div>
        <a href="/lawyer/profile" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-pencil me-1"></i>Edit Profile
        </a>
    </div>

    @if (_loading)
    {
        <LoadingSpinner />
    }
    else
    {
        <!-- Profile Completion -->
        @if (_profile is not null && _profile.ProfileCompletionPercentage < 100)
        {
            <div class="alert alert-warning d-flex align-items-center gap-3 mb-4" role="alert">
                <i class="bi bi-exclamation-circle-fill fs-5"></i>
                <div class="flex-grow-1">
                    <strong>Complete your profile</strong> to get more clients.
                    <div class="profile-completion-bar mt-2" style="height:6px;">
                        <div class="fill" style="width:@_profile.ProfileCompletionPercentage%"></div>
                    </div>
                    <small class="text-muted">@_profile.ProfileCompletionPercentage% complete</small>
                </div>
                <a href="/lawyer/profile" class="btn btn-sm btn-warning">Complete Now</a>
            </div>
        }

        <!-- Stats -->
        <div class="row g-3 mb-4">
            @foreach (var (icon, label, value, color) in _stats)
            {
                <div class="col-6 col-md-3">
                    <div class="stat-card">
                        <div class="stat-icon @color"><i class="@icon"></i></div>
                        <div>
                            <div class="stat-value">@value</div>
                            <div class="stat-label">@label</div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Upcoming Appointments -->
        <div class="lc-card mb-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="fw-bold mb-0">Upcoming Appointments</h6>
                <a href="/lawyer/appointments" class="small">View All</a>
            </div>

            @if (_appointments.Count == 0)
            {
                <p class="text-muted text-center py-3">No upcoming appointments.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle small table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Client</th>
                                <th>Date &amp; Time</th>
                                <th>Fee</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var a in _appointments)
                            {
                                <tr>
                                    <td>@a.ClientName</td>
                                    <td>@a.AppointmentDate.ToString("MMM dd") ·
                                        @DateTime.Today.Add(a.StartTime).ToString("hh:mm tt")
                                    </td>
                                    <td>৳@a.ConsultationFee.ToString("N0")</td>
                                    <td>
                                        <span class="badge @StatusBadge(a.Status)">@a.Status</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <!-- Quick Actions -->
        <div class="row g-3">
            <div class="col-md-4">
                <a href="/lawyer/profile" class="lc-card d-flex align-items-center gap-3 text-decoration-none">
                    <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                        <i class="bi bi-person-badge"></i>
                    </div>
                    <div>
                        <div class="fw-semibold">Manage Profile</div>
                        <div class="small text-muted">Update info, bio, photo</div>
                    </div>
                    <i class="bi bi-chevron-right ms-auto text-muted"></i>
                </a>
            </div>
            <div class="col-md-4">
                <a href="/lawyer/appointments" class="lc-card d-flex align-items-center gap-3 text-decoration-none">
                    <div class="stat-icon bg-success bg-opacity-10 text-success">
                        <i class="bi bi-calendar3"></i>
                    </div>
                    <div>
                        <div class="fw-semibold">Appointments</div>
                        <div class="small text-muted">View &amp; manage bookings</div>
                    </div>
                    <i class="bi bi-chevron-right ms-auto text-muted"></i>
                </a>
            </div>
            <div class="col-md-4">
                <a href="/lawyer/earnings" class="lc-card d-flex align-items-center gap-3 text-decoration-none">
                    <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                        <i class="bi bi-cash-stack"></i>
                    </div>
                    <div>
                        <div class="fw-semibold">Earnings</div>
                        <div class="small text-muted">Revenue summary</div>
                    </div>
                    <i class="bi bi-chevron-right ms-auto text-muted"></i>
                </a>
            </div>
        </div>
    }
</div>

@code {
    private string _name = "";
    private LawyerDto? _profile;
    private List<AppointmentDto> _appointments = [];
    private bool _loading = true;

    private (string, string, string, string)[] _stats =
        Array.Empty<(string, string, string, string)>();

    protected override async Task OnInitializedAsync()
    {
        _name = await AuthService.GetCurrentUserNameAsync() ?? "Lawyer";

        var profileTask = LawyerService.GetMyProfileAsync();
        var apptTask    = AppointmentService.GetLawyerAppointmentsAsync(DateTime.Today, DateTime.Today.AddDays(30));

        await Task.WhenAll(profileTask, apptTask);

        _profile      = profileTask.Result;
        _appointments = apptTask.Result
            .Where(a => a.Status is AppointmentStatus.Pending or AppointmentStatus.Confirmed)
            .OrderBy(a => a.AppointmentDate).ThenBy(a => a.StartTime)
            .Take(5).ToList();

        var all      = apptTask.Result;
        var earned   = all.Where(a => a.Status == AppointmentStatus.Completed).Sum(a => a.ConsultationFee);
        var upcoming = all.Count(a => a.Status == AppointmentStatus.Confirmed);

        _stats = [
            ("bi bi-star-fill",  "Rating",   $"{_profile?.AverageRating:F1}★", "bg-warning bg-opacity-10 text-warning"),
            ("bi bi-people",     "Reviews",  (_profile?.TotalReviews ?? 0).ToString(), "bg-info bg-opacity-10 text-info"),
            ("bi bi-calendar-check", "Upcoming", upcoming.ToString(), "bg-primary bg-opacity-10 text-primary"),
            ("bi bi-cash-stack", "Earned",   $"৳{earned:N0}", "bg-success bg-opacity-10 text-success"),
        ];

        _loading = false;
    }

    private static string StatusBadge(AppointmentStatus s) => s switch
    {
        AppointmentStatus.Confirmed => "bg-success",
        AppointmentStatus.Pending   => "bg-warning text-dark",
        _                           => "bg-secondary"
    };
}
