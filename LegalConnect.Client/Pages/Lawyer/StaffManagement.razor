@page "/lawyer/staff"
@attribute [Authorize(Roles = "Lawyer")]
@inject IStaffService StaffService
@inject NavigationManager Nav
@inject ToastService Toast

<PageTitle>Staff Management</PageTitle>

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-0"><i class="bi bi-people me-2 text-primary"></i>Staff Management</h4>
            <p class="text-muted small mb-0">Manage your firm's staff members</p>
        </div>
        <a href="/lawyer/staff/create" class="btn btn-primary">
            <i class="bi bi-person-plus me-1"></i>Add Staff Member
        </a>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="text-muted mt-2">Loading staff...</p>
        </div>
    }
    else if (_staff.Count == 0)
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-people text-muted" style="font-size:3rem;"></i>
                <h5 class="mt-3 text-muted">No staff members yet</h5>
                <p class="text-muted small">Add your first staff member to get started.</p>
                <a href="/lawyer/staff/create" class="btn btn-primary mt-2">
                    <i class="bi bi-person-plus me-1"></i>Add Staff Member
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Role</th>
                                <th>Status</th>
                                <th>Added</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var staff in _staff)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-circle me-2">@GetInitials(staff.FullName)</div>
                                            <span class="fw-medium">@staff.FullName</span>
                                        </div>
                                    </td>
                                    <td class="text-muted small">@staff.Email</td>
                                    <td><span class="badge @GetRoleBadgeClass(staff.StaffRole)">@staff.StaffRole</span></td>
                                    <td>
                                        @if (staff.IsActive)
                                        {
                                            <span class="badge bg-success-subtle text-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary-subtle text-secondary">Inactive</span>
                                        }
                                    </td>
                                    <td class="text-muted small">@staff.CreatedAt.ToString("MMM d, yyyy")</td>
                                    <td class="text-end">
                                        <button class="btn btn-sm @(staff.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                                @onclick='() => ToggleStaff(staff)'
                                                disabled="@(_toggling == staff.Id)">
                                            @if (_toggling == staff.Id)
                                            {
                                                <span class="spinner-border spinner-border-sm"></span>
                                            }
                                            else
                                            {
                                                @(staff.IsActive ? "Deactivate" : "Activate")
                                            }
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .avatar-circle {
        width: 36px; height: 36px;
        border-radius: 50%;
        background: #e8f0fe;
        color: #4267b2;
        font-size: 0.75rem;
        font-weight: 600;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }
</style>

@code {
    private List<StaffProfileModel> _staff = [];
    private bool _loading = true;
    private int _toggling = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadStaff();
    }

    private async Task LoadStaff()
    {
        _loading = true;
        var result = await StaffService.GetMyStaffAsync();
        if (result?.Success == true)
            _staff = result.Data ?? [];
        _loading = false;
    }

    private async Task ToggleStaff(StaffProfileModel staff)
    {
        _toggling = staff.Id;
        var result = await StaffService.ToggleStaffActiveAsync(staff.Id);
        if (result?.Success == true)
        {
            staff.IsActive = !staff.IsActive;
            Toast.ShowSuccess(result.Message ?? "Status updated.");
        }
        else
        {
            Toast.ShowError(result?.Message ?? "Failed to update status.");
        }
        _toggling = 0;
    }

    private static string GetInitials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[^1][0]}".ToUpper()
            : name.Length > 0 ? name[0].ToString().ToUpper() : "?";
    }

    private static string GetRoleBadgeClass(string role) => role switch
    {
        "Paralegal"  => "bg-primary-subtle text-primary",
        "Associate"  => "bg-info-subtle text-info",
        "Secretary"  => "bg-purple-subtle text-purple",
        "Intern"     => "bg-warning-subtle text-warning",
        _            => "bg-secondary-subtle text-secondary"
    };
}
