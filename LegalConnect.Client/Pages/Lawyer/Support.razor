@page "/lawyer/support"
@attribute [Authorize(Roles = "Lawyer")]
@inject ISupportService SupportService
@inject ToastService Toast
@inject NavigationManager Nav

<PageTitle>Support &mdash; LawCity</PageTitle>

<div class="container py-4" style="max-width:960px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0"><i class="bi bi-life-preserver me-2"></i>My Support Tickets</h3>
        <button class="btn btn-primary btn-sm" @onclick="() => _showCreate = true">
            <i class="bi bi-plus-lg me-1"></i>New Ticket
        </button>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5"><span class="spinner-border text-primary"></span></div>
    }
    else if (_tickets.Count == 0)
    {
        <div class="text-center py-5">
            <i class="bi bi-inbox display-1 text-muted"></i>
            <h5 class="mt-3 text-muted">No support tickets yet</h5>
            <p class="text-muted">Click "New Ticket" to create your first support request.</p>
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Subject</th>
                            <th>Category</th>
                            <th>Priority</th>
                            <th>Status</th>
                            <th>Updated</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in _tickets)
                        {
                            <tr>
                                <td>
                                    <div class="fw-medium">@t.Subject</div>
                                    <div class="text-muted small">@t.MessageCount message(s)</div>
                                </td>
                                <td><span class="badge bg-light text-dark border">@t.Category</span></td>
                                <td><span class="@PriorityBadge(t.Priority)">@t.Priority</span></td>
                                <td><span class="@StatusBadge(t.Status)">@FormatStatus(t.Status)</span></td>
                                <td class="text-muted small">@t.UpdatedAt.ToString("d MMM yyyy")</td>
                                <td>
                                    <a href="/lawyer/support/@t.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@if (_showCreate)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>New Support Ticket</h5>
                    <button type="button" class="btn-close" @onclick="() => _showCreate = false"></button>
                </div>
                <EditForm Model="_createDto" OnValidSubmit="CreateTicketAsync">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Subject <span class="text-danger">*</span></label>
                            <InputText class="form-control" @bind-Value="_createDto.Subject" placeholder="Brief description of your issue" />
                            <ValidationMessage For="() => _createDto.Subject" />
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col-6">
                                <label class="form-label fw-semibold">Category <span class="text-danger">*</span></label>
                                <InputSelect class="form-select" @bind-Value="_createDto.Category">
                                    @foreach (var c in TicketCategories.All)
                                    {
                                        <option value="@c">@c</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="col-6">
                                <label class="form-label fw-semibold">Priority</label>
                                <InputSelect class="form-select" @bind-Value="_createDto.Priority">
                                    @foreach (var p in TicketPriorities.All)
                                    {
                                        <option value="@p">@p</option>
                                    }
                                </InputSelect>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Description <span class="text-danger">*</span></label>
                            <InputTextArea class="form-control" rows="5" @bind-Value="_createDto.Description"
                                           placeholder="Describe your issue in detail..." />
                            <ValidationMessage For="() => _createDto.Description" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="() => _showCreate = false">Cancel</button>
                        <button type="submit" class="btn btn-primary" disabled="@_creating">
                            @if (_creating) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Submit Ticket
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private List<SupportTicketDto> _tickets = [];
    private bool _loading = true;
    private bool _showCreate;
    private bool _creating;
    private CreateSupportTicketDto _createDto = new();

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        var resp = await SupportService.GetMyTicketsAsync();
        _tickets = resp?.Data ?? [];
        _loading = false;
    }

    private async Task CreateTicketAsync()
    {
        _creating = true;
        var resp = await SupportService.CreateTicketAsync(_createDto);
        if (resp?.Success == true)
        {
            Toast.ShowSuccess("Support ticket created!");
            _showCreate = false;
            _createDto = new();
            await LoadAsync();
        }
        else Toast.ShowError(resp?.Message ?? "Failed to create ticket.");
        _creating = false;
    }

    private static string PriorityBadge(string p) => p switch
    {
        "Low" => "badge bg-secondary",
        "Medium" => "badge bg-info",
        "High" => "badge bg-warning text-dark",
        "Urgent" => "badge bg-danger",
        _ => "badge bg-secondary"
    };

    private static string StatusBadge(string s) => s switch
    {
        "Open" => "badge bg-primary",
        "InProgress" => "badge bg-warning text-dark",
        "Resolved" => "badge bg-success",
        "Closed" => "badge bg-secondary",
        _ => "badge bg-secondary"
    };

    private static string FormatStatus(string s) => s switch
    {
        "InProgress" => "In Progress",
        _ => s
    };
}
