@page "/lawyer/tasks"
@attribute [Authorize(Roles = "Lawyer")]
@inject IStaffService StaffService
@inject ICaseService CaseService
@inject ToastService Toast

<PageTitle>Task Management</PageTitle>

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-0"><i class="bi bi-check2-square me-2 text-primary"></i>Task Management</h4>
            <p class="text-muted small mb-0">Assign and track tasks for your staff</p>
        </div>
        <button class="btn btn-primary" @onclick='() => _showCreateForm = !_showCreateForm'>
            <i class="bi bi-plus-lg me-1"></i>New Task
        </button>
    </div>

    @* ── Create / Edit Form ───────────────────────────────────────────── *@
    @if (_showCreateForm || _editingTask != null)
    {
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-light py-2 d-flex justify-content-between align-items-center">
                <span class="fw-semibold">@(_editingTask != null ? "Edit Task" : "New Task")</span>
                <button class="btn btn-sm btn-link text-muted" @onclick="CancelForm">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            <div class="card-body p-3">
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label small fw-medium">Title <span class="text-danger">*</span></label>
                        <input type="text" class="form-control form-control-sm" @bind="_form.Title" placeholder="Task title..." />
                    </div>
                    <div class="col-12">
                        <label class="form-label small fw-medium">Description</label>
                        <textarea class="form-control form-control-sm" rows="2" @bind="_form.Description" placeholder="Optional details..."></textarea>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-medium">Assign To</label>
                        <select class="form-select form-select-sm" @bind="_form.AssignedToStaffProfileId">
                            <option value="">— Unassigned —</option>
                            @foreach (var s in _staff)
                            {
                                <option value="@s.Id">@s.FullName (@s.StaffRole)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-medium">Link to Case</label>
                        <select class="form-select form-select-sm" @bind="_form.CaseId">
                            <option value="">— No Case —</option>
                            @foreach (var c in _cases)
                            {
                                <option value="@c.Id">@c.CaseTitle</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small fw-medium">Priority</label>
                        <select class="form-select form-select-sm" @bind="_form.Priority">
                            @foreach (var p in TaskPriorityType.All)
                            {
                                <option value="@p">@p</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small fw-medium">Due Date</label>
                        <input type="date" class="form-control form-control-sm" @bind="_form.DueDate" />
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(_formError))
                {
                    <div class="alert alert-danger mt-2 py-1 small mb-0">@_formError</div>
                }
                <div class="d-flex gap-2 mt-3">
                    <button class="btn btn-sm btn-primary" @onclick="SaveTask" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        @(_editingTask != null ? "Save Changes" : "Create Task")
                    </button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="CancelForm">Cancel</button>
                </div>
            </div>
        </div>
    }

    @* ── Filters ─────────────────────────────────────────────────────── *@
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body py-2 px-3">
            <div class="row g-2 align-items-end">
                <div class="col-auto">
                    <label class="form-label small mb-1">Status</label>
                    <select class="form-select form-select-sm" @bind="_filterStatus">
                        <option value="">All</option>
                        @foreach (var s in StaffTaskStatusType.All)
                        {
                            <option value="@s">@s</option>
                        }
                    </select>
                </div>
                <div class="col-auto">
                    <label class="form-label small mb-1">Priority</label>
                    <select class="form-select form-select-sm" @bind="_filterPriority">
                        <option value="">All</option>
                        @foreach (var p in TaskPriorityType.All)
                        {
                            <option value="@p">@p</option>
                        }
                    </select>
                </div>
                <div class="col-auto">
                    <label class="form-label small mb-1">Assigned To</label>
                    <select class="form-select form-select-sm" @bind="_filterStaffId">
                        <option value="0">All Staff</option>
                        @foreach (var s in _staff)
                        {
                            <option value="@s.Id">@s.FullName</option>
                        }
                    </select>
                </div>
                <div class="col">
                    <input type="text" class="form-control form-control-sm" @bind="_filterSearch"
                           placeholder="Search title..." />
                </div>
            </div>
        </div>
    </div>

    @* ── Task Table ───────────────────────────────────────────────────── *@
    @if (_loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else
    {
        var filtered = FilteredTasks.ToList();
        @if (filtered.Count == 0)
        {
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center py-5">
                    <i class="bi bi-clipboard-check text-muted" style="font-size:2.5rem;"></i>
                    <p class="text-muted mt-2 mb-0">No tasks found.</p>
                </div>
            </div>
        }
        else
        {
            <div class="card border-0 shadow-sm">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0 small">
                            <thead class="table-light">
                                <tr>
                                    <th>Title</th>
                                    <th>Assigned To</th>
                                    <th>Case</th>
                                    <th>Priority</th>
                                    <th>Status</th>
                                    <th>Due Date</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var task in filtered)
                                {
                                    <tr class="@(task.IsOverdue ? "table-danger" : "")">
                                        <td>
                                            <div class="fw-medium">@task.Title</div>
                                            @if (!string.IsNullOrEmpty(task.Description))
                                            {
                                                <div class="text-muted small text-truncate" style="max-width:200px;">@task.Description</div>
                                            }
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(task.AssignedToName))
                                            {
                                                <span>@task.AssignedToName</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">Unassigned</span>
                                            }
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(task.CaseTitle))
                                            {
                                                <span class="text-truncate" style="max-width:120px; display:inline-block;">@task.CaseTitle</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">&mdash;</span>
                                            }
                                        </td>
                                        <td><span class="badge @GetPriorityBadge(task.Priority)">@task.Priority</span></td>
                                        <td><span class="badge @GetStatusBadge(task.Status)">@task.Status</span></td>
                                        <td class="@(task.IsOverdue ? "fw-bold text-danger" : "text-muted")">
                                            @(task.DueDate.HasValue ? task.DueDate.Value.ToString("MMM d") : "—")
                                        </td>
                                        <td class="text-end">
                                            <button class="btn btn-xs btn-outline-primary me-1"
                                                    @onclick='() => EditTask(task)' title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-xs btn-outline-danger"
                                                    @onclick='() => DeleteTask(task.Id)' title="Delete"
                                                    disabled="@(_deleting == task.Id)">
                                                @if (_deleting == task.Id)
                                                {
                                                    <span class="spinner-border spinner-border-sm"></span>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-trash"></i>
                                                }
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    }
</div>

<style>
    .btn-xs { padding: 0.15rem 0.4rem; font-size: 0.75rem; }
</style>

@code {
    private List<StaffTaskModel>    _tasks    = [];
    private List<StaffProfileModel> _staff    = [];
    private List<CaseSummaryDto>    _cases    = [];
    private bool _loading = true;
    private bool _showCreateForm = false;
    private bool _saving = false;
    private int  _deleting = 0;
    private string? _formError;

    // Filters
    private string _filterStatus   = "";
    private string _filterPriority = "";
    private int    _filterStaffId  = 0;
    private string _filterSearch   = "";

    // Form state
    private TaskFormModel   _form        = new();
    private StaffTaskModel? _editingTask = null;

    private IEnumerable<StaffTaskModel> FilteredTasks => _tasks.Where(t =>
        (string.IsNullOrEmpty(_filterStatus)   || t.Status   == _filterStatus) &&
        (string.IsNullOrEmpty(_filterPriority) || t.Priority == _filterPriority) &&
        (_filterStaffId == 0 || t.AssignedToStaffProfileId == _filterStaffId) &&
        (string.IsNullOrEmpty(_filterSearch)   || t.Title.Contains(_filterSearch, StringComparison.OrdinalIgnoreCase)));

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadTasks(), LoadStaff(), LoadCases());
        _loading = false;
    }

    private async Task LoadTasks()
    {
        var result = await StaffService.GetAllTasksAsync();
        if (result?.Success == true) _tasks = result.Data ?? [];
    }

    private async Task LoadStaff()
    {
        var result = await StaffService.GetMyStaffAsync();
        if (result?.Success == true) _staff = (result.Data ?? []).Where(s => s.IsActive).ToList();
    }

    private async Task LoadCases()
    {
        var result = await CaseService.GetCasesAsync(new CaseFilterDto { PageSize = 100 });
        if (result?.Success == true) _cases = result.Data?.Items ?? [];
    }

    private void EditTask(StaffTaskModel task)
    {
        _editingTask = task;
        _form = new TaskFormModel
        {
            Title                    = task.Title,
            Description              = task.Description,
            AssignedToStaffProfileId = task.AssignedToStaffProfileId,
            CaseId                   = task.CaseId,
            Priority                 = task.Priority,
            DueDate                  = task.DueDate
        };
        _showCreateForm = true;
    }

    private void CancelForm()
    {
        _showCreateForm = false;
        _editingTask    = null;
        _form           = new();
        _formError      = null;
    }

    private async Task SaveTask()
    {
        if (string.IsNullOrWhiteSpace(_form.Title))
        {
            _formError = "Title is required.";
            return;
        }
        _saving    = true;
        _formError = null;

        if (_editingTask != null)
        {
            var update = new UpdateStaffTaskModel
            {
                Title                    = _form.Title,
                Description              = _form.Description,
                AssignedToStaffProfileId = _form.AssignedToStaffProfileId,
                CaseId                   = _form.CaseId,
                Priority                 = _form.Priority,
                DueDate                  = _form.DueDate
            };
            var result = await StaffService.UpdateTaskAsync(_editingTask.Id, update);
            if (result?.Success == true)
            {
                Toast.ShowSuccess("Task updated.");
                await LoadTasks();
                CancelForm();
            }
            else _formError = result?.Message ?? "Update failed.";
        }
        else
        {
            var create = new CreateStaffTaskModel
            {
                Title                    = _form.Title,
                Description              = _form.Description,
                AssignedToStaffProfileId = _form.AssignedToStaffProfileId,
                CaseId                   = _form.CaseId,
                Priority                 = _form.Priority,
                DueDate                  = _form.DueDate
            };
            var result = await StaffService.CreateTaskAsync(create);
            if (result?.Success == true)
            {
                Toast.ShowSuccess("Task created.");
                await LoadTasks();
                CancelForm();
            }
            else _formError = result?.Message ?? "Create failed.";
        }
        _saving = false;
    }

    private async Task DeleteTask(int id)
    {
        _deleting = id;
        var result = await StaffService.DeleteTaskAsync(id);
        if (result?.Success == true)
        {
            _tasks.RemoveAll(t => t.Id == id);
            Toast.ShowSuccess("Task deleted.");
        }
        else Toast.ShowError(result?.Message ?? "Delete failed.");
        _deleting = 0;
    }

    private static string GetPriorityBadge(string p) => p switch
    {
        "Urgent" => "bg-danger",
        "High"   => "bg-warning text-dark",
        "Low"    => "bg-info-subtle text-info",
        _        => "bg-secondary-subtle text-secondary"
    };

    private static string GetStatusBadge(string s) => s switch
    {
        "Completed"  => "bg-success",
        "InProgress" => "bg-primary",
        "Cancelled"  => "bg-secondary",
        _            => "bg-warning text-dark"
    };

    private class TaskFormModel
    {
        public string   Title                    { get; set; } = string.Empty;
        public string?  Description              { get; set; }
        public int?     AssignedToStaffProfileId { get; set; }
        public int?     CaseId                   { get; set; }
        public string   Priority                 { get; set; } = TaskPriorityType.Medium;
        public DateTime? DueDate                 { get; set; }
    }
}
