@page "/staff/my-cases"
@attribute [Authorize(Roles = "Staff")]
@implements IDisposable
@inject ICaseService CaseService
@inject NavigationManager Nav

<PageTitle>My Assigned Cases</PageTitle>

<div class="container-fluid py-4">

    <div class="mb-4">
        <h4 class="fw-bold mb-0"><i class="bi bi-folder2-open me-2 text-primary"></i>My Assigned Cases</h4>
        <p class="text-muted small mb-0">Cases you have been assigned to by your firm</p>
    </div>

    @* ── Search bar ───────────────────────────────────────────────────── *@
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body py-2 px-3">
            <div class="row g-2">
                <div class="col-md-5">
                    <input type="text" class="form-control form-control-sm"
                           @bind="_filter.SearchTerm" @bind:event="oninput"
                           @onkeyup="OnSearchKeyUp"
                           placeholder="Search by title, type, court..." />
                </div>
                <div class="col-auto">
                    <select class="form-select form-select-sm" @bind="_filter.Status" @bind:after="LoadCasesAsync">
                        <option value="">All Status</option>
                        @foreach (var s in Enum.GetValues<CaseStatus>())
                        {
                            <option value="@s">@s</option>
                        }
                    </select>
                </div>
                <div class="col-auto">
                    <button class="btn btn-sm btn-primary" @onclick="LoadCasesAsync">
                        <i class="bi bi-search me-1"></i>Search
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="text-muted mt-2">Loading cases...</p>
        </div>
    }
    else if (_cases.Count == 0)
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-folder2 text-muted" style="font-size:3rem;"></i>
                <h5 class="mt-3 text-muted">No cases assigned yet</h5>
                <p class="text-muted small">Your lawyer will assign cases to you.</p>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Case</th>
                                <th>Client</th>
                                <th>Type</th>
                                <th>Court</th>
                                <th>Status</th>
                                <th>Next Hearing</th>
                                <th class="text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in _cases)
                            {
                                <tr style="cursor:pointer" @onclick='() => Nav.NavigateTo($"/staff/cases/{c.Id}")'>
                                    <td>
                                        <div class="fw-medium">@c.CaseTitle</div>
                                        @if (!string.IsNullOrEmpty(c.CaseNumber))
                                        {
                                            <div class="text-muted small"><i class="bi bi-hash"></i>@c.CaseNumber</div>
                                        }
                                    </td>
                                    <td class="small">@c.ClientName</td>
                                    <td class="small text-muted">@c.CaseType</td>
                                    <td class="small text-muted">@c.Court</td>
                                    <td><span class="@c.StatusBadgeClass">@c.Status</span></td>
                                    <td class="small @(c.NextHearingDate.HasValue && c.NextHearingDate < DateTime.Today ? "text-danger fw-bold" : "text-muted")">
                                        @(c.NextHearingDate.HasValue ? c.NextHearingDate.Value.ToString("MMM d, yyyy") : "—")
                                    </td>
                                    <td class="text-end">
                                        <a href="/staff/cases/@c.Id" class="btn btn-sm btn-outline-primary py-0 px-2"
                                           @onclick:stopPropagation="true">
                                            <i class="bi bi-eye me-1"></i>View
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @* ── Pagination ───────────────────────────────────────────────── *@
        @if (_totalPages > 1)
        {
            <div class="d-flex justify-content-between align-items-center mt-3">
                <span class="text-muted small">
                    Showing @((_filter.PageNumber - 1) * _filter.PageSize + 1)&ndash;@(Math.Min(_filter.PageNumber * _filter.PageSize, _totalCount)) of @_totalCount cases
                </span>
                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(_filter.PageNumber == 1 ? "disabled" : "")">
                            <button class="page-link" @onclick="() => GoToPage(_filter.PageNumber - 1)">
                                <i class="bi bi-chevron-left"></i>
                            </button>
                        </li>
                        @for (int p = 1; p <= _totalPages; p++)
                        {
                            var pageNum = p;
                            <li class="page-item @(_filter.PageNumber == pageNum ? "active" : "")">
                                <button class="page-link" @onclick="() => GoToPage(pageNum)">@pageNum</button>
                            </li>
                        }
                        <li class="page-item @(_filter.PageNumber == _totalPages ? "disabled" : "")">
                            <button class="page-link" @onclick="() => GoToPage(_filter.PageNumber + 1)">
                                <i class="bi bi-chevron-right"></i>
                            </button>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    }
</div>

@code {
    private List<CaseSummaryDto> _cases      = [];
    private CaseFilterDto        _filter      = new() { PageSize = 15, SortBy = "modifieddate", SortDescending = true };
    private bool                 _loading     = true;
    private int                  _totalCount  = 0;
    private int                  _totalPages  = 1;
    private System.Timers.Timer? _searchTimer;

    protected override async Task OnInitializedAsync()
    {
        await LoadCasesAsync();
    }

    private async Task LoadCasesAsync()
    {
        _loading = true;
        var result = await CaseService.GetCasesAsync(_filter);
        if (result?.Success == true && result.Data != null)
        {
            _cases      = result.Data.Items;
            _totalCount = result.Data.TotalCount;
            _totalPages = (int)Math.Ceiling(_totalCount / (double)_filter.PageSize);
        }
        _loading = false;
    }

    private void OnSearchKeyUp(KeyboardEventArgs e)
    {
        _searchTimer?.Stop();
        _searchTimer?.Dispose();
        _searchTimer = new System.Timers.Timer(400);
        _searchTimer.Elapsed += async (_, _) =>
        {
            _searchTimer?.Dispose();
            _filter.PageNumber = 1;
            await InvokeAsync(async () => { await LoadCasesAsync(); StateHasChanged(); });
        };
        _searchTimer.AutoReset = false;
        _searchTimer.Start();
    }

    private async Task GoToPage(int page)
    {
        _filter.PageNumber = page;
        await LoadCasesAsync();
    }

    public void Dispose() => _searchTimer?.Dispose();
}
