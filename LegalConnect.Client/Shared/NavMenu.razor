    <NavLink class="nav-link" href="/client/appointments">
        <i class="bi bi-calendar-check"></i> My Appointments
    </NavLink>

    <NavLink class="nav-link" href="/client/my-cases">
        <i class="bi bi-folder2-open"></i> My Cases
    </NavLink>

    <NavLink class="nav-link" href="/client/documents">
        <i class="bi bi-folder2"></i> Documents
    </NavLink>

    <NavLink class="nav-link" href="/client/hire-lawyers">
